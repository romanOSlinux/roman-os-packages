# Scriptlet para registrar la firma en el llavero local de pacman al instalar/actualizar el paquete

post_install() {
    if [ -x usr/bin/pacman-key ]; then
        echo ">>> Inicializando llavero GPG de Roman OS en pacman..."
        pacman-key --add /usr/share/pacman/keyrings/roman-os.gpg
        pacman-key --lsign-key romanoslinux@protonmail.com
    fi
}

post_upgrade() {
    post_install
}
