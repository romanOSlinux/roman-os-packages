# Maintainer: Roman <romanOSlinux>
pkgname=roman-os-plymouth
pkgver=1.0
pkgrel=1
pkgdesc="Tema Plymouth sencillo para Roman OS"
arch=('any')
url="https://github.com/romanOSlinux/roman-os-packages"
license=('GPL')
depends=('plymouth')
install=roman-os-plymouth.install
provides=('plymouth-theme-kiro-logo')
conflicts=('plymouth-theme-kiro-logo')
source=('roman-os.plymouth' 'roman-os.script' 'roman-os-logo.png')
sha256sums=('SKIP' 'SKIP' 'SKIP')

package() {
    cd "$srcdir"

    # Instalar tema de Plymouth
    install -dm755 "$pkgdir/usr/share/plymouth/themes/roman-os"
    install -m644 roman-os.plymouth "$pkgdir/usr/share/plymouth/themes/roman-os/"
    install -m644 roman-os.script "$pkgdir/usr/share/plymouth/themes/roman-os/"
    install -m644 roman-os-logo.png "$pkgdir/usr/share/plymouth/themes/roman-os/"
}
