#!/bin/bash
set -euo pipefail
#####################################################################
# Author    : Erik Dubois
# Website   : https://kiroproject.be
#####################################################################
#
#   DO NOT JUST RUN THIS. EXAMINE AND JUDGE. RUN AT YOUR OWN RISK.
#
#   Purpose:
#   Comprehensive post-install audit of a Kiro system. Checks kernel,
#   microcode, mkinitcpio, audio stack, Calamares cleanup, kiro_final
#   configuration, pacman repositories, desktop environments, SDDM,
#   user groups, systemd services and drop-ins, udev rules, file
#   permissions, bootloader, and package integrity. `--fix` auto-remediates
#   known issues. Re-runs itself as root (polkit popup or sudo) if needed.
#
#   Why: verifies an installed Kiro system matches the intended
#   specification; catches drift between what the ISO is supposed to
#   deliver and what's actually on the machine. Run monthly.
#
#####################################################################

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

#####################################################################
# Colors
#####################################################################
if command -v tput >/dev/null 2>&1 && [[ -t 1 ]]; then
    RED="$(tput setaf 1)"
    GREEN="$(tput setaf 2)"
    YELLOW="$(tput setaf 3)"
    BLUE="$(tput setaf 4)"
    CYAN="$(tput setaf 6)"
    RESET="$(tput sgr0)"
else
    RED="" GREEN="" YELLOW="" BLUE="" CYAN="" RESET=""
fi

#####################################################################
# Logging
#####################################################################
log_section() {
    echo
    echo "${GREEN}############################################################################${RESET}"
    echo "$1"
    echo "${GREEN}############################################################################${RESET}"
    echo
}

log_info() {
    echo
    echo "${BLUE}############################################################################${RESET}"
    echo "$1"
    echo "${BLUE}############################################################################${RESET}"
    echo
}

log_warn() {
    echo
    echo "${YELLOW}############################################################################${RESET}"
    echo "$1"
    echo "${YELLOW}############################################################################${RESET}"
    echo
}

log_error() {
    echo
    echo "${RED}############################################################################${RESET}"
    echo "$1"
    echo "${RED}############################################################################${RESET}"
    echo
}

log_success() {
    echo
    echo "${GREEN}############################################################################${RESET}"
    echo "$1"
    echo "${GREEN}############################################################################${RESET}"
    echo
}

#####################################################################
# Error handling
#####################################################################
on_error() {
    local lineno="$1"
    local cmd="$2"
    echo
    echo "${RED}ERROR on line ${lineno}: ${cmd}${RESET}"
    echo
    sleep 10
}

trap 'on_error "$LINENO" "$BASH_COMMAND"' ERR

#####################################################################
# Privilege — re-exec as root (polkit popup in a GUI, sudo over SSH/tty)
#####################################################################
# kiro-audit is self-contained and does NOT source kiro-common.sh, so it
# carries its own copy of this helper. Keep it in sync with kiro-common.sh.
ensure_root() {
    [[ $EUID -eq 0 ]] && return 0
    trap - ERR
    local self
    self="$(realpath "${BASH_SOURCE[-1]}")"
    if [[ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]] && command -v pkexec >/dev/null 2>&1; then
        echo "${YELLOW}$(basename "$self") needs root — requesting your password...${RESET}" >&2
        exec pkexec env TERM="${TERM:-xterm-256color}" "$self" "$@"
    fi
    echo "${YELLOW}$(basename "$self") needs root — re-running with sudo...${RESET}" >&2
    exec sudo "$self" "$@"
}

FIX_MODE=false
FORCE=false

for _arg in "$@"; do
    case "$_arg" in
        -h|--help)
            cat <<'EOF'
kiro-audit - Kiro ISO installed system audit

Usage:
    kiro-audit [--help] [--version] [--fix] [--force]

Options:
    -h, --help     Show this help message and exit
    -v, --version  Show version information and exit
    --fix          Auto-remediate known fixable failures (requires root)
    --force        Run even in the live ISO (checks assume an installed system)

Description:
    Comprehensive post-install audit of a Kiro system. Checks kernel,
    microcode, mkinitcpio, audio stack, Calamares cleanup, kiro_final
    configuration, pacman repositories, desktop environments, SDDM,
    user groups, systemd services, file permissions, bootloader, and
    package integrity.

    In read-only mode (default), fixable FAILs show a FIX? hint with
    the command that --fix would run.

    Requires root. If not run as root, it re-elevates automatically:
    a polkit password popup in a graphical session, or a sudo prompt
    over SSH/tty.

For more information, visit: https://www.erikdubois.be
EOF
            exit 0
            ;;
        -v|--version)
            show_version "$(basename "$0")" "${BASH_SOURCE[0]}"
            exit 0
            ;;
        --fix)
            FIX_MODE=true
            ;;
        --force)
            FORCE=true
            ;;
    esac
done
unset _arg

# Live-ISO guard: kiro-audit audits an *installed* Kiro system. In the live ISO the root
# is a read-only squashfs and the archiso packages/config are still present, so most checks
# FAIL on things that don't apply. Bail before the root prompt unless --force.
if [[ -d /run/archiso ]] && [[ "${FORCE}" != true ]]; then
    log_warn "Live ISO detected — kiro-audit is for an INSTALLED Kiro system"
    echo "  The live ISO root is a read-only squashfs with the archiso packages and config"
    echo "  still present, so most checks would FAIL on things that don't apply here. Install"
    echo "  Kiro first, then run kiro-audit on the installed system."
    echo
    echo "  Run 'kiro-audit --force' to audit the live environment anyway."
    echo
    exit 0
fi

ensure_root "$@"

#####################################################################
# Counters
#####################################################################
PASS=0
FAIL=0
WARN=0
FIXED=0

pass() { echo "  ${GREEN}PASS${RESET}  $1"; PASS=$((PASS + 1)); }
fail() { echo "  ${RED}FAIL${RESET}  $1"; FAIL=$((FAIL + 1)); }
warn() { echo "  ${YELLOW}WARN${RESET}  $1"; WARN=$((WARN + 1)); }

# apply_fix "description" cmd [args...]
# --fix mode: prints description and runs cmd; increments FIXED on success.
# read-only mode: prints a FIX? hint showing what would run.
apply_fix() {
    local msg="$1"; shift
    if [[ "${FIX_MODE}" == true ]]; then
        echo "  ${CYAN}FIX${RESET}   ${msg}"
        if "$@"; then
            FIXED=$((FIXED + 1))
        else
            echo "  ${RED}ERR${RESET}   fix failed: $*"
        fi
    else
        echo "  ${CYAN}FIX?${RESET}  --fix: ${msg}"
    fi
}

pkg_installed()  { pacman -Q "$1" &>/dev/null; }
pkg_missing()    { ! pacman -Q "$1" &>/dev/null; }

#####################################################################
# Functions
#####################################################################
detect_kernels() {
    # Emit installed kernel pkgbases, one per line, sorted & deduped.
    # Source: /usr/lib/modules/*/pkgbase (every Arch kernel package drops one).
    # Used by check_kernel + check_mkinitcpio so the audit works on whatever
    # kernel(s) the system ships (linux-lqx / linux-zen / linux-hardened / ...).
    local f
    for f in /usr/lib/modules/*/pkgbase; do
        [[ -f "${f}" ]] && cat "${f}"
    done | sort -u
}

check_kernel() {
    log_section "Kernel"

    local -a kernels=()
    mapfile -t kernels < <(detect_kernels)

    if [[ ${#kernels[@]} -eq 0 ]]; then
        fail "No installed kernels detected (no /usr/lib/modules/*/pkgbase)"
        return
    fi

    pass "Installed kernel(s): ${kernels[*]}"

    # Running kernel must have a matching modules tree (catches mid-upgrade boots).
    local running running_pkgbase
    running=$(uname -r)
    if [[ -f "/usr/lib/modules/${running}/pkgbase" ]]; then
        running_pkgbase=$(<"/usr/lib/modules/${running}/pkgbase")
        pass "Running kernel: ${running} (${running_pkgbase})"
    else
        warn "Running kernel ${running} has no /usr/lib/modules entry — reboot pending after upgrade?"
    fi

    # Per-kernel artifact + package validation (supports multi-kernel installs).
    local k
    for k in "${kernels[@]}"; do
        [[ -f "/boot/vmlinuz-${k}" ]]        && pass "/boot/vmlinuz-${k} present"        || fail "/boot/vmlinuz-${k} missing"
        [[ -f "/boot/initramfs-${k}.img" ]]  && pass "/boot/initramfs-${k}.img present"  || fail "/boot/initramfs-${k}.img missing"
        pkg_installed "${k}"            && pass "${k} package installed"             || fail "${k} package not installed"
        pkg_installed "${k}-headers"    && pass "${k}-headers installed"             || fail "${k}-headers not installed"
    done
}

check_microcode() {
    log_section "Microcode"

    if [[ -f /boot/intel-ucode.img ]]; then
        pass "intel-ucode.img present in /boot"
        pkg_missing amd-ucode && pass "amd-ucode not installed (Intel system)" || warn "amd-ucode also installed on Intel system"
    elif [[ -f /boot/amd-ucode.img ]]; then
        pass "amd-ucode.img present in /boot"
        pkg_missing intel-ucode && pass "intel-ucode not installed (AMD system)" || warn "intel-ucode also installed on AMD system"
    elif systemd-detect-virt --vm --quiet 2>/dev/null; then
        pass "No microcode image in /boot — expected, this is a virtual machine (not real metal)"
    else
        fail "No microcode image found in /boot"
    fi
}

check_mkinitcpio() {
    log_section "mkinitcpio"

    local hooks
    hooks=$(grep '^HOOKS=' /etc/mkinitcpio.conf | head -1)

    # Must NOT have archiso hook
    if echo "${hooks}" | grep -q 'archiso'; then
        fail "archiso hook still present in mkinitcpio.conf HOOKS"
    else
        pass "No archiso hook in mkinitcpio.conf"
    fi

    # Must have microcode and kms
    echo "${hooks}" | grep -q 'microcode' && pass "microcode hook present" || fail "microcode hook missing from HOOKS"
    echo "${hooks}" | grep -q 'kms'       && pass "kms hook present"       || fail "kms hook missing from HOOKS"

    # Each installed kernel must have its preset (kernel-agnostic).
    local -a kernels=()
    mapfile -t kernels < <(detect_kernels)
    local k
    for k in "${kernels[@]}"; do
        [[ -f "/etc/mkinitcpio.d/${k}.preset" ]] \
            && pass "${k}.preset exists" \
            || fail "${k}.preset missing"
    done

    # Stock linux.preset is a leftover only when the linux package isn't installed
    # (Calamares strip step on Kiro's non-stock kernels). When linux IS installed,
    # the per-kernel loop above already covered it.
    if ! pkg_installed linux; then
        if [[ -f /etc/mkinitcpio.d/linux.preset ]]; then
            fail "linux.preset leftover not cleaned up (linux package isn't installed)"
        else
            pass "linux.preset leftover not present (good)"
        fi
    fi
}

check_audio() {
    log_section "Audio stack"

    for pkg in pipewire pipewire-alsa pipewire-audio pipewire-pulse wireplumber; do
        pkg_installed "${pkg}" && pass "${pkg} installed" || fail "${pkg} missing"
    done

    pkg_missing pulseaudio && pass "pulseaudio not installed (good)" || fail "pulseaudio still installed — conflicts with PipeWire"
}

check_calamares_cleanup() {
    log_section "Calamares cleanup"

    pkg_missing calamares              && pass "calamares binary removed"              || fail "calamares still installed"
    pkg_missing mkinitcpio-archiso     && pass "mkinitcpio-archiso removed"            || fail "mkinitcpio-archiso still installed"
    pkg_missing memtest86+             && pass "memtest86+ removed"                    || warn "memtest86+ still installed"
    pkg_missing kiro-calamares-tweak-tool && pass "kiro-calamares-tweak-tool removed"  || fail "kiro-calamares-tweak-tool still installed (install-time tool leaked to user)"
    if pkg_missing kiro-calamares-config-next; then
        pass "kiro-calamares-config-next removed"
        [[ -d /etc/calamares ]] && warn "/etc/calamares config dir still present after package removal" || pass "/etc/calamares directory removed"
    else
        fail "kiro-calamares-config-next still installed (kiro_final removal step failed)"
    fi

    # kiro_final live-only artifact cleanup
    if [[ -f /root/.automated_script.sh ]]; then
        fail "/root/.automated_script.sh archiso leftover present"
        apply_fix "rm /root/.automated_script.sh" rm /root/.automated_script.sh
    else
        pass "No /root/.automated_script.sh (good)"
    fi

    if [[ -f /root/.zlogin ]]; then
        fail "/root/.zlogin archiso leftover present"
        apply_fix "rm /root/.zlogin" rm /root/.zlogin
    else
        pass "No /root/.zlogin (good)"
    fi

    if [[ -d /etc/systemd/system/getty@tty1.service.d ]]; then
        fail "getty@tty1 autologin not cleaned up"
        apply_fix "rm -rf /etc/systemd/system/getty@tty1.service.d" rm -rf /etc/systemd/system/getty@tty1.service.d
    else
        pass "getty@tty1 autologin removed (good)"
    fi

    if [[ -f /etc/sudoers.d/g_wheel ]]; then
        fail "/etc/sudoers.d/g_wheel live-only rule still present"
        apply_fix "rm /etc/sudoers.d/g_wheel" rm /etc/sudoers.d/g_wheel
    else
        pass "/etc/sudoers.d/g_wheel removed (good)"
    fi

    if [[ -f /etc/polkit-1/rules.d/49-nopasswd_global.rules ]]; then
        fail "49-nopasswd_global.rules live-only rule still present"
        apply_fix "rm /etc/polkit-1/rules.d/49-nopasswd_global.rules" rm /etc/polkit-1/rules.d/49-nopasswd_global.rules
    else
        pass "49-nopasswd_global.rules removed (good)"
    fi

}

check_kiro_final_config() {
    log_section "kiro_final configuration"

    # /root permissions
    local root_perm
    root_perm=$(stat -c '%a' /root 2>/dev/null)
    [[ "${root_perm}" == "700" ]] && pass "/root permissions: 700" || fail "/root permissions wrong: ${root_perm} (expected 700)"

    # sudoers.d permissions
    local sudoers_perm
    sudoers_perm=$(stat -c '%a' /etc/sudoers.d 2>/dev/null)
    [[ "${sudoers_perm}" == "750" ]] && pass "/etc/sudoers.d permissions: 750" || fail "/etc/sudoers.d permissions wrong: ${sudoers_perm} (expected 750)"

    # polkit-1/rules.d permissions
    local polkit_perm
    polkit_perm=$(stat -c '%a' /etc/polkit-1/rules.d 2>/dev/null || echo "missing")
    [[ "${polkit_perm}" == "750" ]] && pass "/etc/polkit-1/rules.d permissions: 750" || fail "/etc/polkit-1/rules.d permissions wrong: ${polkit_perm} (expected 750)"

    # EDITOR=nano in /etc/profile
    grep -q 'EDITOR=nano' /etc/profile 2>/dev/null && pass "EDITOR=nano set in /etc/profile" || fail "EDITOR=nano not set in /etc/profile"

    # Bluetooth AutoEnable
    grep -q '^AutoEnable=true' /etc/bluetooth/main.conf 2>/dev/null && pass "Bluetooth AutoEnable=true" || fail "Bluetooth AutoEnable not set in /etc/bluetooth/main.conf"

    # makepkg.conf optimizations (kiro_before)
    local nproc_count makeflags_j lower
    nproc_count=$(nproc)
    makeflags_j=$(grep '^MAKEFLAGS=' /etc/makepkg.conf 2>/dev/null | grep -oP '(?<=-j)\d+' || echo "0")
    # Kiro deliberately leaves 1–2 CPUs free (the flow scripts set -j to nproc-1 / nproc-2
    # for headroom), so -j in [nproc-2 .. nproc] is correct here, not a WARN.
    lower=$(( nproc_count > 2 ? nproc_count - 2 : 1 ))
    if [[ "${makeflags_j}" -ge "${lower}" && "${makeflags_j}" -le "${nproc_count}" ]]; then
        pass "makepkg.conf MAKEFLAGS=-j${makeflags_j} (Kiro leaves 1–2 CPUs free; ${nproc_count} total)"
    elif [[ "${makeflags_j}" -gt 0 ]]; then
        warn "makepkg.conf MAKEFLAGS=-j${makeflags_j}; expected ${lower}–${nproc_count} on this ${nproc_count}-CPU system"
    else
        fail "makepkg.conf MAKEFLAGS not set"
    fi
    grep -q "^PKGEXT='.pkg.tar.zst'" /etc/makepkg.conf 2>/dev/null && pass "makepkg.conf PKGEXT=.pkg.tar.zst" || fail "makepkg.conf PKGEXT not set to .pkg.tar.zst"
    grep -qP '^OPTIONS=.*!debug' /etc/makepkg.conf 2>/dev/null && pass "makepkg.conf !debug in OPTIONS" || fail "makepkg.conf debug not disabled in OPTIONS"
}

check_pacman_repos() {
    log_section "Pacman repositories"

    grep -q '^\[nemesis_repo\]' /etc/pacman.conf && pass "nemesis_repo in pacman.conf" || fail "nemesis_repo missing from pacman.conf"
    grep -q '^\[chaotic-aur\]'  /etc/pacman.conf && pass "chaotic-aur in pacman.conf"  || fail "chaotic-aur missing from pacman.conf"

    # cachyos may legitimately be enabled (chwd drivers during install; and going
    # forward, cachyos niri / cachyos hyprland packages) or shipped commented — both
    # are fine, so an active [cachyos] is a PASS, not a WARN. We still verify that an
    # *enabled* block is backed by its keyring + mirrorlist, or pacman syncs break.
    if grep -q '^\[cachyos\]' /etc/pacman.conf; then
        pass "cachyos repo enabled (fine — drivers / niri / hyprland come from it)"
        # An active [cachyos] block REQUIRES the keyring (signature verification)
        # and the mirrorlist file (the block's Include= target) — without them
        # every pacman sync fails. ATT's cachyos toggle bootstraps both (bundled
        # packages + setup-cachyos) before enabling; this verifies that held.
        pkg_installed cachyos-keyring \
            && pass "cachyos-keyring installed (required by active [cachyos])" \
            || fail "cachyos enabled but cachyos-keyring missing — pacman will reject signatures"
        [[ -f /etc/pacman.d/cachyos-mirrorlist ]] \
            && pass "cachyos-mirrorlist present (required by active [cachyos])" \
            || fail "cachyos enabled but /etc/pacman.d/cachyos-mirrorlist missing — Include= will break pacman"
    elif grep -qE '^#\s*\[cachyos\]' /etc/pacman.conf; then
        pass "cachyos repo commented out (opt-in, as shipped)"
    else
        warn "cachyos repo entry absent from pacman.conf (expected present-but-commented)"
    fi

    # ── Package signing (PGP) ──────────────────────────────────────────────
    # Kiro signs nemesis_repo / kiro_repo packages; the kiro-keyring package ships
    # and locally-trusts the Kiro signing key. The one dangerous misconfiguration
    # is a repo at SigLevel = Required/Optional while the key is absent — pacman
    # then rejects every package from it and syncs break. SigLevel = Never is the
    # accepted transitional state while the keyring propagates across the fleet.
    local kiro_key="149ABD0C3A0563EE"
    local kiro_key_present="no"
    if pacman-key --list-keys "${kiro_key}" &>/dev/null; then
        pass "Kiro signing key trusted in pacman keyring (${kiro_key})"
        kiro_key_present="yes"
    else
        warn "Kiro signing key NOT in pacman keyring — (re)install kiro-keyring or run 'pacman-key --populate kiro'"
    fi

    # Effective SigLevel = per-repo override if present, else the global [options]
    # value. Kiro deliberately ships the repos with NO per-repo SigLevel so they
    # inherit the global Required DatabaseOptional — so an empty per-repo line is
    # correct, not a misconfiguration; resolve to the global before judging.
    local global_sig
    global_sig="$(awk '$0=="[options]"{f=1;next} f&&/^\[/{f=0} f&&/^SigLevel/{print $3; exit}' /etc/pacman.conf)"

    local repo siglevel effective src
    for repo in nemesis_repo kiro_repo; do
        grep -q "^\[${repo}\]" /etc/pacman.conf || continue
        siglevel="$(awk -v r="[${repo}]" '$0==r{f=1;next} f&&/^\[/{f=0} f&&/^SigLevel/{print $3; exit}' /etc/pacman.conf)"
        if [[ -n "${siglevel}" ]]; then
            effective="${siglevel}"; src="explicit"
        else
            effective="${global_sig}"; src="inherited from [options]"
        fi
        case "${effective}" in
            Required|Optional)
                if [[ "${kiro_key_present}" == "yes" ]]; then
                    pass "${repo} verifies signatures (SigLevel ${effective}, ${src}) and the Kiro key is trusted"
                else
                    fail "${repo} SigLevel=${effective} (${src}) but the Kiro key is absent — pacman will reject every ${repo} package"
                fi
                ;;
            Never)
                warn "${repo} not verifying signatures (SigLevel Never, ${src}) — transitional; tightens once kiro-keyring is fleet-wide"
                ;;
            "")
                warn "${repo} has no SigLevel and [options] sets none — pacman's built-in default applies; set a global SigLevel"
                ;;
            *)
                warn "${repo} unexpected effective SigLevel '${effective}'"
                ;;
        esac
    done

    # multilib is intentionally NOT shipped (gaming-only: Wine/Steam 32-bit libs);
    # users enable it via one click in ATT. No audit row — silence is correct.
}

check_desktop() {
    log_section "Desktop environments"

    # Edition-agnostic: KIB can build any edition (XFCE, ohmychadwm, the TWMs, Budgie, …),
    # so we don't demand a specific desktop — we verify at least one valid login session
    # exists, scanning both X11 and Wayland session files.
    local -a sessions=()
    local d f
    for d in /usr/share/xsessions /usr/share/wayland-sessions; do
        [[ -d "$d" ]] || continue
        for f in "$d"/*.desktop; do
            [[ -e "$f" ]] && sessions+=("$(basename "$f" .desktop)")
        done
    done
    if (( ${#sessions[@]} > 0 )); then
        pass "desktop session(s) installed: ${sessions[*]}"
    else
        fail "no desktop session found (none in /usr/share/xsessions or /usr/share/wayland-sessions)"
    fi

    pkg_missing edu-chadwm && pass "edu-chadwm not installed (dropped)" || warn "edu-chadwm still installed — should be removed"
}

check_sddm() {
    log_section "SDDM"

    pkg_installed sddm && pass "sddm installed" || fail "sddm not installed"
    systemctl is-enabled sddm &>/dev/null && pass "sddm.service enabled" || fail "sddm.service not enabled"

    if grep -q 'edu-simplicity' /etc/sddm.conf.d/*.conf 2>/dev/null || grep -q 'edu-simplicity' /etc/sddm.conf 2>/dev/null; then
        pass "SDDM theme set to edu-simplicity"
    else
        warn "SDDM theme not set to edu-simplicity"
    fi
}

check_user_groups() {
    log_section "User groups"

    local user
    user=$(getent passwd 1000 | cut -d: -f1)
    if [[ -z "${user}" ]]; then
        warn "No user with UID 1000 found — skipping group checks"
        return
    fi

    log_info "Checking groups for user: ${user}"
    local groups
    groups=$(groups "${user}")

    for grp in wheel audio video storage optical network; do
        echo "${groups}" | grep -q "${grp}" && pass "${user} in group: ${grp}" || fail "${user} not in group: ${grp}"
    done
}

check_services() {
    log_section "Systemd services"

    for svc in NetworkManager sddm bluetooth; do
        systemctl is-enabled "${svc}" &>/dev/null && pass "${svc} enabled" || warn "${svc} not enabled"
    done

    # These should NOT be enabled on installed system
    if systemctl is-enabled pacman-init &>/dev/null; then
        fail "pacman-init still enabled (archiso leftover)"
        apply_fix "systemctl mask pacman-init" systemctl mask pacman-init
    else
        pass "pacman-init not enabled (good)"
    fi
    systemctl is-enabled reflector   &>/dev/null && warn "reflector enabled (was this intentional?)" || true

    # cgroup delegation for user sessions (required by ananicy-cpp)
    local delegate="/usr/lib/systemd/system/user@.service.d/delegate.conf"
    if [[ -f "${delegate}" ]]; then
        grep -q 'Delegate=' "${delegate}" \
            && pass "user@.service.d/delegate.conf present (cgroup delegation enabled)" \
            || fail "user@.service.d/delegate.conf present but Delegate= line missing"
    else
        fail "user@.service.d/delegate.conf missing — ananicy-cpp cgroup support broken"
    fi

    # ananicy-cpp must be installed and enabled
    pkg_installed ananicy-cpp \
        && pass "ananicy-cpp installed" \
        || fail "ananicy-cpp not installed"
    systemctl is-enabled ananicy-cpp &>/dev/null \
        && pass "ananicy-cpp.service enabled" \
        || fail "ananicy-cpp.service not enabled"

    # firewalld — shipped on the ISO and enabled via Calamares (security baseline)
    pkg_installed firewalld \
        && pass "firewalld installed" \
        || warn "firewalld not installed"
    systemctl is-enabled firewalld &>/dev/null \
        && pass "firewalld.service enabled" \
        || warn "firewalld.service not enabled"

    # logrotate.timer — enabled via Calamares so file-based logs (pacman.log,
    # Xorg/app logs) rotate; journald rotates its own store separately
    if systemctl is-enabled logrotate.timer &>/dev/null; then
        pass "logrotate.timer enabled"
    else
        warn "logrotate.timer not enabled (file-based logs won't rotate)"
        apply_fix "systemctl enable logrotate.timer" systemctl enable logrotate.timer
    fi
}

check_permissions() {
    log_section "Key file permissions"

    local shadow_perm gshadow_perm
    shadow_perm=$(stat -c '%a' /etc/shadow   2>/dev/null || echo "missing")
    gshadow_perm=$(stat -c '%a' /etc/gshadow 2>/dev/null || echo "missing")

    [[ "${shadow_perm}"  == "400" ]] && pass "/etc/shadow permissions: 400"   || fail "/etc/shadow permissions wrong: ${shadow_perm} (expected 400)"
    [[ "${gshadow_perm}" == "400" ]] && pass "/etc/gshadow permissions: 400"  || fail "/etc/gshadow permissions wrong: ${gshadow_perm} (expected 400)"

    if [[ -f /etc/cups/classes.conf ]]; then
        local cups_class_perm
        cups_class_perm=$(stat -c '%a' /etc/cups/classes.conf)
        if [[ "${cups_class_perm}" == "600" ]]; then
            pass "/etc/cups/classes.conf permissions: 600"
        else
            fail "/etc/cups/classes.conf permissions wrong: ${cups_class_perm} (expected 600)"
            apply_fix "chmod 600 /etc/cups/classes.conf" chmod 600 /etc/cups/classes.conf
        fi
    fi

    if [[ -f /etc/cups/printers.conf ]]; then
        local cups_printers_perm
        cups_printers_perm=$(stat -c '%a' /etc/cups/printers.conf)
        if [[ "${cups_printers_perm}" == "600" ]]; then
            pass "/etc/cups/printers.conf permissions: 600"
        else
            fail "/etc/cups/printers.conf permissions wrong: ${cups_printers_perm} (expected 600)"
            apply_fix "chmod 600 /etc/cups/printers.conf" chmod 600 /etc/cups/printers.conf
        fi
    fi
}

check_dev_rel() {
    log_section "ISO version"

    if [[ -f /etc/dev-rel ]]; then
        pass "/etc/dev-rel present"
        echo "  ${CYAN}INFO${RESET}  $(cat /etc/dev-rel)"
    else
        fail "/etc/dev-rel missing"
    fi
}

check_nvidia() {
    log_section "NVIDIA"

    if lspci 2>/dev/null | grep -qi nvidia; then
        log_info "NVIDIA GPU detected"
        pkg_installed nvidia-open-dkms  && pass "nvidia-open-dkms installed"  || warn "NVIDIA GPU present but nvidia-open-dkms not installed"
        pkg_installed nvidia-utils       && pass "nvidia-utils installed"       || warn "nvidia-utils not installed"
    else
        pass "No NVIDIA GPU detected — DKMS packages not expected"
        pkg_missing nvidia-open-dkms && pass "nvidia-open-dkms not installed (no GPU, good)" || warn "nvidia-open-dkms installed but no NVIDIA GPU detected"
    fi
}

check_chwd() {
    log_section "chwd driver install"

    # The Calamares chwd module leaves this breadcrumb when it could not install
    # the detected driver profile (e.g. a profile package was missing from the
    # configured repos). The install is allowed to finish on the open driver, so
    # this is a WARN, not a FAIL — the system is usable but lacks the profile.
    local marker="/var/log/kiro-chwd-skipped.log"
    if [[ -f "${marker}" ]]; then
        warn "chwd was skipped during install — open driver in use (see ${marker})"
        while read -r line; do
            echo "        ${line}"
        done < "${marker}"
    else
        pass "No chwd skip marker (driver autoconfigure completed, or driver=free)"
    fi
}

check_package_integrity() {
    log_section "Package integrity (pacman -Qk)"

    local missing
    missing=$(pacman -Qk 2>/dev/null \
        | grep -v ' 0 missing files$' \
        | grep 'missing files' \
        | grep -v '^ohmychadwm:' \
        | grep -v '^bind:' \
        | grep -v '^cups:' \
        | grep -v '^nfs-utils:') || true

    if [[ -z "${missing}" ]]; then
        pass "All packages have no missing files"
    else
        fail "Packages with missing files:"
        echo "${missing}" | while read -r line; do
            echo "        ${line}"
        done
    fi
}

check_sysctl_security() {
    log_section "Sysctl security baseline"

    local key expected actual
    declare -A expected_values=(
        [kernel.kptr_restrict]=2
        [kernel.dmesg_restrict]=1
        [kernel.yama.ptrace_scope]=1
        [kernel.unprivileged_bpf_disabled]=1
        [kernel.perf_event_paranoid]=3
        [fs.suid_dumpable]=0
        [net.ipv4.conf.all.send_redirects]=0
        [net.ipv4.tcp_syncookies]=1
    )

    for key in "${!expected_values[@]}"; do
        expected="${expected_values[$key]}"
        actual=$(sysctl -n "${key}" 2>/dev/null || echo "unavailable")
        if [[ "${actual}" == "unavailable" ]]; then
            warn "${key} not supported by this kernel"
        elif [[ "${actual}" == "${expected}" ]]; then
            pass "${key} = ${actual}"
        else
            fail "${key} = ${actual} (expected ${expected})"
        fi
    done
}

check_zram() {
    log_section "ZRAM"

    pkg_installed zram-generator && pass "zram-generator installed" || fail "zram-generator not installed"
    [[ -f /etc/systemd/zram-generator.conf ]] && pass "zram-generator.conf present" || fail "zram-generator.conf missing"
    [[ -b /dev/zram0 ]] && pass "/dev/zram0 device present" || fail "/dev/zram0 not present — ZRAM not active"

    if [[ -b /dev/zram0 ]]; then
        if swapon --show | grep -q zram0; then
            local zram_size
            zram_size=$(swapon --show --noheadings | grep zram0 | awk '{print $3}')
            pass "/dev/zram0 active as swap (${zram_size})"
        else
            fail "/dev/zram0 exists but not active as swap"
        fi

        local algo
        algo=$(zramctl --noheadings -o ALGORITHM /dev/zram0 2>/dev/null || echo "unknown")
        [[ "${algo}" == "zstd" ]] && pass "ZRAM compression: zstd" || warn "ZRAM compression: ${algo} (expected zstd)"
    fi
}

check_udev_rules() {
    log_section "Udev rules"

    # All rule files the edu-system-files package ships
    local expected_rules=(
        60-io-scheduler.rules
        60-ioschedulers-tuning.rules
        61-audio-power.rules
        62-network-optimization.rules
        63-usb-optimization.rules
        64-gpu-optimization.rules
        65-storage-optimization.rules
        66-input-optimization.rules
        67-laptop-optimization.rules
        68-sound-power.rules
    )
    local r
    for r in "${expected_rules[@]}"; do
        [[ -f "/etc/udev/rules.d/${r}" ]] && pass "udev rule present: ${r}" || fail "udev rule missing: ${r}"
    done

    # IO scheduler — correct assignment per device type (from CachyOS research)
    local rules_file="/etc/udev/rules.d/60-io-scheduler.rules"
    if [[ -f "${rules_file}" ]]; then
        grep -q 'rotational.*=="0".*mq-deadline\|mq-deadline.*rotational.*=="0"' "${rules_file}" \
            && pass "IO scheduler: SSD → mq-deadline" \
            || fail "IO scheduler: SSD not set to mq-deadline (check 60-io-scheduler.rules)"
        grep -q 'rotational.*=="1".*bfq\|bfq.*rotational.*=="1"' "${rules_file}" \
            && pass "IO scheduler: HDD → bfq" \
            || fail "IO scheduler: HDD not set to bfq (check 60-io-scheduler.rules)"
        grep -q 'nvme.*none\|none.*nvme' "${rules_file}" \
            && pass "IO scheduler: NVMe → none" \
            || warn "IO scheduler: NVMe rule not found in 60-io-scheduler.rules"
    fi
}

check_systemd_dropins() {
    log_section "Systemd drop-ins"

    local dropins=(
        /etc/systemd/system.conf.d/10-kiro-system.conf
        /etc/systemd/system.conf.d/90-memory-accounting.conf
        /etc/systemd/journald.conf.d/10-kiro-journal.conf
        /etc/systemd/coredump.conf.d/10-kiro-coredump.conf
        /etc/systemd/user.conf.d/10-kiro-user.conf
    )
    local f
    for f in "${dropins[@]}"; do
        [[ -f "${f}" ]] && pass "drop-in present: ${f#/etc/systemd/}" || fail "drop-in missing: ${f#/etc/systemd/}"
    done
}

check_modprobe_thp() {
    log_section "Modprobe & THP tuning"

    local f
    for f in intel-ethernet.conf realtek-ethernet.conf; do
        [[ -f "/etc/modprobe.d/${f}" ]] && pass "modprobe.d/${f} present" || fail "modprobe.d/${f} missing"
    done

    [[ -f /etc/tmpfiles.d/thp-tuning.conf ]] \
        && pass "tmpfiles.d/thp-tuning.conf present" \
        || fail "tmpfiles.d/thp-tuning.conf missing"
}

check_garuda_imports() {
    # 5 items adopted from Garuda 2026-05-28
    # See: kiro-iso/docs/garuda-comparison-2026-05-28.md
    log_section "Garuda imports (2026-05-28)"

    # 1. systemd-oomd — config drop-ins + active daemon
    local oomd_files=(
        /etc/systemd/oomd.conf.d/10-kiro-oomd.conf
        /etc/systemd/system/system.slice.d/10-kiro-oomd-per-slice.conf
        /etc/systemd/user/slice.d/10-kiro-oomd-per-slice.conf
    )
    local f
    for f in "${oomd_files[@]}"; do
        [[ -f "${f}" ]] && pass "oomd drop-in: ${f#/etc/systemd/}" || fail "oomd drop-in missing: ${f#/etc/systemd/}"
    done
    if systemctl is-enabled systemd-oomd &>/dev/null; then
        pass "systemd-oomd.service enabled"
    else
        fail "systemd-oomd.service not enabled (drop-ins are dead config without it)"
        apply_fix "systemctl enable systemd-oomd" systemctl enable systemd-oomd
    fi
    if systemctl is-active systemd-oomd &>/dev/null; then
        pass "systemd-oomd.service active"
    else
        warn "systemd-oomd.service not active (will start at next boot if enabled)"
    fi

    # 2. Intel ME blacklist (privacy + attack surface)
    if [[ -f /etc/modprobe.d/blacklist-intel-me.conf ]] \
       && grep -q '^blacklist mei$' /etc/modprobe.d/blacklist-intel-me.conf \
       && grep -q '^blacklist mei_me$' /etc/modprobe.d/blacklist-intel-me.conf; then
        pass "modprobe.d/blacklist-intel-me.conf present (mei + mei_me blacklisted)"
    else
        fail "modprobe.d/blacklist-intel-me.conf missing or incomplete"
    fi
    # Confirm modules are not actually loaded
    if lsmod | grep -qE '^mei(_me)?\b'; then
        warn "mei/mei_me still loaded — blacklist not honored (initramfs rebuild needed?)"
    else
        pass "mei/mei_me not loaded"
    fi

    # 3. btusb reset=1 (Bluetooth USB suspend/resume fix)
    if [[ -f /etc/modprobe.d/bluetooth-usb.conf ]] \
       && grep -q '^options btusb reset=1' /etc/modprobe.d/bluetooth-usb.conf; then
        pass "modprobe.d/bluetooth-usb.conf present (btusb reset=1)"
    else
        fail "modprobe.d/bluetooth-usb.conf missing or wrong"
    fi

    # 4. Disable kernel zswap (zram-generator owns swap)
    if [[ -f /etc/tmpfiles.d/disable-zswap.conf ]] \
       && grep -q '/sys/module/zswap/parameters/enabled' /etc/tmpfiles.d/disable-zswap.conf; then
        pass "tmpfiles.d/disable-zswap.conf present"
    else
        fail "tmpfiles.d/disable-zswap.conf missing"
    fi
    local zswap_state
    zswap_state=$(cat /sys/module/zswap/parameters/enabled 2>/dev/null || echo "?")
    case "${zswap_state}" in
        N|0) pass "zswap disabled at runtime" ;;
        Y|1) fail "zswap still enabled at runtime — tmpfile not applied yet (reboot or systemd-tmpfiles --create)" ;;
        *)   warn "zswap state unreadable (${zswap_state}) — kernel may not expose /sys/module/zswap" ;;
    esac

    # 5. NetworkManager unmanaged-lo
    if [[ -f /etc/NetworkManager/conf.d/unmanaged-lo.conf ]] \
       && grep -q 'interface-name:lo' /etc/NetworkManager/conf.d/unmanaged-lo.conf; then
        pass "NetworkManager conf.d/unmanaged-lo.conf present"
    else
        fail "NetworkManager conf.d/unmanaged-lo.conf missing"
    fi
}


check_resolved_config() {
    log_section "systemd-resolved configuration"

    local drop_in
    drop_in=$(grep -rl 'MulticastDNS=no' /etc/systemd/resolved.conf /etc/systemd/resolved.conf.d/ 2>/dev/null | head -1 || true)
    if [[ -n "${drop_in}" ]]; then
        pass "MulticastDNS=no set (${drop_in}) — avahi owns mDNS"
    else
        warn "MulticastDNS not disabled in systemd-resolved; may conflict with avahi-daemon"
    fi

    local hosts_no
    hosts_no=$(grep -rl 'ReadEtcHosts=no' /etc/systemd/resolved.conf /etc/systemd/resolved.conf.d/ 2>/dev/null | head -1 || true)
    if [[ -n "${hosts_no}" ]]; then
        pass "ReadEtcHosts=no set (${hosts_no}) — resolved skips hBlock hosts file"
    else
        warn "ReadEtcHosts not disabled; resolved will parse /etc/hosts on every boot (slow with hBlock)"
    fi
}

check_tuned_profile() {
    log_section "tuned-ppd power profile"

    # Source of truth on an installed Kiro system:
    #   /etc/tuned/ppd_base_profile must contain "performance"
    #   tuned-adm active must report "throughput-performance"
    # Background: the tuned package's pacman install writes ppd_base_profile=balanced,
    # which short-circuits ppd.conf's `default=performance` fallback. kiro_final
    # overwrites it with "performance" so the throughput-performance active_profile holds.
    if [[ ! -f /etc/tuned/ppd_base_profile ]]; then
        warn "/etc/tuned/ppd_base_profile missing (tuned not installed?)"
        return
    fi

    local base
    base=$(tr -d '[:space:]' < /etc/tuned/ppd_base_profile)
    if [[ "${base}" == "performance" ]]; then
        pass "ppd_base_profile = performance (kiro_final pin held)"
    else
        fail "ppd_base_profile = ${base} (expected performance — kiro_final pin lost)"
    fi

    if ! command -v tuned-adm >/dev/null 2>&1; then
        warn "tuned-adm not found; cannot verify active profile"
        return
    fi

    local active
    active=$(tuned-adm active 2>/dev/null | awk -F': ' '{print $2}')
    if [[ "${active}" == "throughput-performance" ]]; then
        pass "tuned-adm active = throughput-performance"
    else
        fail "tuned-adm active = ${active:-unknown} (expected throughput-performance)"
    fi
}

check_tumbler() {
    log_section "Tumbler / thumbnailing"

    pkg_installed libgepub \
        && pass "libgepub installed (tumbler EPUB thumbnailer)" \
        || fail "libgepub missing — tumbler logs 'cannot open shared object file: libgepub-0.7.so.0' on every file-manager launch"
}

check_failed_units() {
    log_section "Failed systemd units"

    local failed_count
    failed_count=$(systemctl --failed --no-legend 2>/dev/null | wc -l)

    if [[ "${failed_count}" -eq 0 ]]; then
        pass "No failed systemd units"
    else
        fail "${failed_count} failed systemd unit(s):"
        systemctl --failed --no-legend | while read -r line; do
            echo "        ${line}"
        done
    fi
}

check_boot_and_updates() {
    log_section "Boot time and updates (info)"

    local boot_summary
    boot_summary=$(systemd-analyze 2>/dev/null | head -1)
    echo "  ${CYAN}INFO${RESET}  Boot: ${boot_summary}"

    local update_count
    update_count=$(checkupdates 2>/dev/null | wc -l || true)
    if [[ "${update_count}" -eq 0 ]]; then
        echo "  ${CYAN}INFO${RESET}  Pending updates: 0"
    else
        echo "  ${YELLOW}INFO${RESET}  Pending updates: ${update_count} package(s) available"
    fi
}

check_bootloader() {
    log_section "Bootloader"

    if [[ -d /sys/firmware/efi ]]; then
        pass "System booted via UEFI"
        if command -v bootctl &>/dev/null && [[ "$(bootctl is-installed 2>/dev/null)" == "yes" ]]; then
            pass "systemd-boot is installed"
        elif [[ -d /boot/grub ]] || pkg_installed grub; then
            pass "GRUB EFI bootloader detected"
        else
            warn "UEFI system but bootloader type unclear"
        fi
    else
        pass "System booted via BIOS"
        { [[ -d /boot/grub ]] || pkg_installed grub; } && pass "GRUB BIOS bootloader detected" || warn "BIOS system but no GRUB found"
    fi

    # --- Kiro GRUB boot-safety hooks (kiro-bootloader-grub) ---
    # Only meaningful when GRUB is the LIVE bootloader (loader.conf absent AND
    # grub.cfg present — same discriminator as kiro-grub-is-active). grub being
    # *installed* on a systemd-boot box is NOT a fault: ISO builders legitimately
    # need it (archiso optdepend), so grub presence is never flagged here.
    if [[ ! -f /boot/efi/loader/loader.conf && -f /boot/grub/grub.cfg ]]; then
        if [[ -x /usr/bin/kiro-grub-install && -f /usr/share/libalpm/hooks/kiro-grub-install.hook ]]; then
            pass "GRUB boot-safety hooks installed (grub-install on grub upgrade)"
        elif pkg_installed kiro-bootloader-grub || pkg_installed kiro-bootloader-grub-nemesis; then
            fail "boot-safety package installed but hook/helper missing"
        fi
        # else: package not shipped yet (pre-promotion) -> stay silent
    fi
}

check_btrfs_snapshots() {
    log_section "Btrfs snapshots"

    # Only meaningful on a btrfs root. On ext4/xfs/etc. (and on the live ISO, which
    # is not btrfs) the snapshot stack simply does not apply — pass and move on.
    local root_fstype
    root_fstype=$(findmnt -no FSTYPE / 2>/dev/null || echo "")
    if [[ "${root_fstype}" != "btrfs" ]]; then
        pass "Root filesystem is ${root_fstype:-unknown}, not btrfs — snapshot stack not applicable"
        return
    fi

    # ISO side: Calamares pre-stages @snapshots -> /.snapshots on every btrfs install
    # so a later snapper create-config drops in clean instead of nesting inside @.
    if findmnt -no TARGET /.snapshots &>/dev/null; then
        pass "/.snapshots subvolume mounted (Kiro layout pre-staged by Calamares)"
    else
        warn "/.snapshots not mounted — @snapshots subvolume missing (snapper would nest inside @)"
    fi

    # The snapshot stack is OPT-IN via ATT (Btrfs page). A btrfs install with none of
    # it is the expected shipped default, not a failure. Only once the user has opted
    # in do we verify the configuration matches Kiro policy: snap-pac + cleanup, NO
    # hourly timeline.
    local any_installed=false config_present=false pkg
    for pkg in snapper snap-pac btrfs-assistant btrfsmaintenance; do
        pkg_installed "${pkg}" && any_installed=true
    done
    [[ -f /etc/snapper/configs/root ]] && config_present=true

    if [[ "${any_installed}" == false && "${config_present}" == false ]]; then
        pass "Snapshot stack not installed — opt-in via ATT > Btrfs (expected default)"
        return
    fi

    # User has opted in — verify the whole stack and the Kiro policy landed.
    for pkg in snapper snap-pac btrfs-assistant btrfsmaintenance; do
        pkg_installed "${pkg}" && pass "${pkg} installed" || fail "${pkg} not installed (snapshot setup incomplete)"
    done

    if [[ "${config_present}" == true ]]; then
        pass "snapper root config present (/etc/snapper/configs/root)"

        # Kiro policy: snapshots fire on pacman actions via snap-pac, NO hourly timeline.
        local timeline
        timeline=$(grep -E '^TIMELINE_CREATE=' /etc/snapper/configs/root | head -1 | cut -d= -f2 | tr -d '"' || true)
        if [[ "${timeline}" == "no" ]]; then
            pass "TIMELINE_CREATE=no (Kiro policy — snapshots on pacman actions only)"
        else
            fail "TIMELINE_CREATE=${timeline:-unset} (expected no — Kiro ships snap-pac without hourly timeline)"
            apply_fix "snapper -c root set-config TIMELINE_CREATE=no" snapper -c root set-config TIMELINE_CREATE=no
        fi
    else
        fail "Tools installed but no snapper root config — half-configured (run ATT > Btrfs > Enable Kiro snapshots)"
    fi

    # Cleanup timer prunes the snap-pac pre/post pairs.
    if systemctl is-enabled snapper-cleanup.timer &>/dev/null; then
        pass "snapper-cleanup.timer enabled"
    else
        fail "snapper-cleanup.timer not enabled (snap-pac pairs will accumulate)"
        apply_fix "systemctl enable --now snapper-cleanup.timer" systemctl enable --now snapper-cleanup.timer
    fi

    # Timeline timer must stay OFF (Kiro policy — no hourly snapshots).
    if systemctl is-enabled snapper-timeline.timer &>/dev/null; then
        fail "snapper-timeline.timer enabled (Kiro policy is no hourly timeline)"
        apply_fix "systemctl disable --now snapper-timeline.timer" systemctl disable --now snapper-timeline.timer
    else
        pass "snapper-timeline.timer not enabled (Kiro policy)"
    fi

    # btrfsmaintenance scrub/balance/trim timers are driven by the refresh .path unit.
    if systemctl is-enabled btrfsmaintenance-refresh.path &>/dev/null; then
        pass "btrfsmaintenance-refresh.path enabled (scrub · balance · trim)"
    else
        warn "btrfsmaintenance-refresh.path not enabled (scrub/balance/trim timers not installed)"
    fi
}

check_disk_format() {
    log_section "Disk format & encryption"

    # The partitioning/filesystem layout is a user choice in the Calamares
    # partition step (ext4 or btrfs root, optional full-disk LUKS, optional
    # encrypted swap). This check reports the chosen layout as INFO, then — only
    # when LUKS is actually in use — asserts the encryption is sound. On the
    # default unencrypted install it is a single informational pass.
    local root_fs root_src
    root_fs=$(findmnt -no FSTYPE / 2>/dev/null || echo "unknown")
    root_src=$(findmnt -no SOURCE / 2>/dev/null || echo "")

    local -a luks_devs=()
    mapfile -t luks_devs < <(lsblk -rpno NAME,FSTYPE 2>/dev/null | awk '$2=="crypto_LUKS"{print $1}')

    if [[ ${#luks_devs[@]} -eq 0 ]]; then
        echo "  ${CYAN}INFO${RESET}  Root filesystem: ${root_fs} (unencrypted)"
        pass "No LUKS containers — unencrypted install (expected default)"
        return
    fi

    echo "  ${CYAN}INFO${RESET}  Root filesystem: ${root_fs} on ${root_src}"
    echo "  ${CYAN}INFO${RESET}  LUKS containers: ${#luks_devs[@]} (${luks_devs[*]})"
    pass "Full-disk encryption in use (${#luks_devs[@]} LUKS container(s))"

    # Each container must be LUKS2 — the modern Calamares default (argon2id PBKDF).
    # LUKS1 still unlocks but is legacy (PBKDF2), so warn rather than fail. The
    # cipher is reported as INFO so the audit shows the actual formatting choice.
    local dev ver cipher
    for dev in "${luks_devs[@]}"; do
        ver=$(cryptsetup luksDump "${dev}" 2>/dev/null | awk -F: '/^Version:/{gsub(/[[:space:]]/,"",$2); print $2}')
        cipher=$(cryptsetup luksDump "${dev}" 2>/dev/null | awk -F: '/[Cc]ipher:/{gsub(/^[[:space:]]+/,"",$2); print $2; exit}')
        echo "  ${CYAN}INFO${RESET}  ${dev}: cipher ${cipher:-unknown}"
        case "${ver}" in
            2) pass "${dev}: LUKS2" ;;
            1) warn "${dev}: LUKS1 (legacy — Calamares default is LUKS2/argon2id)" ;;
            *) warn "${dev}: LUKS version undetermined (${ver:-unknown})" ;;
        esac
    done

    # An encrypted root needs an initramfs unlock hook or the next mkinitcpio
    # rebuild would lock the system out. Calamares uses sd-encrypt (systemd init,
    # Kiro's default) or the busybox encrypt hook — accept either.
    local hooks
    hooks=$(grep '^HOOKS=' /etc/mkinitcpio.conf 2>/dev/null | head -1)
    if echo "${hooks}" | grep -qE '\b(sd-encrypt|encrypt)\b'; then
        pass "mkinitcpio HOOKS has a LUKS unlock hook (sd-encrypt/encrypt)"
    else
        fail "encrypted root but no sd-encrypt/encrypt hook in mkinitcpio HOOKS — next initramfs rebuild would lock the system out"
    fi

    # Calamares embeds /crypto_keyfile.bin in the initramfs so the passphrase is
    # typed once at boot. It must never be group/other readable.
    if [[ -f /crypto_keyfile.bin ]]; then
        local kf_perm kf_own
        kf_perm=$(stat -c '%a' /crypto_keyfile.bin)
        kf_own=$(stat -c '%U:%G' /crypto_keyfile.bin)
        if [[ "${kf_perm}" =~ ^[46]00$ && "${kf_own}" == "root:root" ]]; then
            pass "/crypto_keyfile.bin secured (${kf_perm} ${kf_own})"
        else
            fail "/crypto_keyfile.bin loose permissions: ${kf_perm} ${kf_own} (expected 600 root:root)"
            apply_fix "chmod 600 /crypto_keyfile.bin" chmod 600 /crypto_keyfile.bin
        fi
    fi

    # Positive confirmation the container(s) are actually unlocked (each real
    # dm-crypt line carries a tab; "No devices found" does not).
    local crypt_open
    crypt_open=$(dmsetup ls --target crypt 2>/dev/null | grep -c $'\t' || true)
    if [[ "${crypt_open}" -gt 0 ]]; then
        pass "Active dm-crypt mapping(s): ${crypt_open}"
    else
        warn "No active dm-crypt mapping found despite LUKS containers"
    fi
}

# Resolve the EFFECTIVE X cursor for a user through the real lookup chain and
# record where it came from. Sets globals CURSOR_VAL / CURSOR_SRC (a command
# substitution can't set globals, so this returns via globals, not stdout).
CURSOR_VAL=""
CURSOR_SRC=""
resolve_cursor() {
    local u="$1" h="$2"
    CURSOR_VAL=""
    CURSOR_SRC=""
    CURSOR_VAL=$(sudo -H -u "${u}" kreadconfig6 --file kcminputrc --group Mouse --key cursorTheme 2>/dev/null || true)
    [[ -n "${CURSOR_VAL}" ]] && { CURSOR_SRC="~/.config/kcminputrc"; return; }
    if [[ -r "${h}/.icons/default/index.theme" ]]; then
        CURSOR_VAL=$(awk -F= '/^Inherits=/{print $2; exit}' "${h}/.icons/default/index.theme" 2>/dev/null || true)
        [[ -n "${CURSOR_VAL}" ]] && { CURSOR_SRC="~/.icons/default/index.theme"; return; }
    fi
    if [[ -r /usr/share/icons/default/index.theme ]]; then
        CURSOR_VAL=$(awk -F= '/^Inherits=/{print $2; exit}' /usr/share/icons/default/index.theme 2>/dev/null || true)
        local owner
        owner=$(pacman -Qqo /usr/share/icons/default/index.theme 2>/dev/null || true)
        [[ -n "${CURSOR_VAL}" ]] && { CURSOR_SRC="/usr/share/icons/default/index.theme${owner:+ (${owner})}"; return; }
    fi
    CURSOR_SRC="(none found)"
}

check_kiro_plasma() {
    # Only relevant on a Plasma install — silent no-op on the tiling/XFCE editions
    pkg_installed plasma-desktop || command -v plasmashell &>/dev/null || return 0

    log_section "Kiro Plasma theme/config"

    local pkgs
    pkgs=$(pacman -Qq 2>/dev/null | grep '^kiro-plasma-' || true)
    if [[ -z "${pkgs}" ]]; then
        warn "Plasma installed but no kiro-plasma-* packages present"
        return 0
    fi

    local user home_dir
    user=$(getent passwd 1000 | cut -d: -f1)
    home_dir=$(getent passwd 1000 | cut -d: -f6)

    # ── 1) Delivery: each package's /etc/skel + /etc/xdg config ──────────────
    #   /etc/xdg = system-default cascade (applies to everyone)
    #   /etc/skel = seeds NEW accounts only — a pre-existing UID-1000 user
    #   won't have it, which is expected, so that is a warn not a fail.
    local pkg files f rel
    while IFS= read -r pkg; do
        [[ -n "${pkg}" ]] || continue
        files=$(pacman -Ql "${pkg}" 2>/dev/null | awk '{print $2}' | grep -E '^/etc/(skel|xdg)/' | grep -vE '/$' || true)
        [[ -n "${files}" ]] || continue
        while IFS= read -r f; do
            [[ -f "${f}" ]] || continue
            if [[ "${f}" == /etc/xdg/* ]]; then
                rel="${f#/etc/xdg/}"
                pass "${pkg}: /etc/xdg/${rel} present (system default layer)"
            else
                rel="${f#/etc/skel/}"
                if [[ -n "${home_dir}" && -e "${home_dir}/${rel}" ]]; then
                    pass "${pkg}: ${rel} seeded into ${user}'s home"
                else
                    warn "${pkg}: /etc/skel/${rel} ships but not in ${user:-user}'s home (skel only seeds NEW accounts)"
                fi
            fi
        done <<<"${files}"
    done <<<"${pkgs}"

    # ── 2) Visual inventory: for each element the ACTIVE Kiro look-and-feel
    #   declares (cursor, colour scheme, icons, widget style, decoration),
    #   list what the user's session actually has and whether it is SET to the
    #   intended value, DIFFERS, or is NOT SET (falling back to a cascade /
    #   system default). Many of these only apply when the user actively
    #   selects the Global Theme, so NOT SET is a normal state, not a failure —
    #   hence warn, never fail. The cursor is resolved through its real lookup
    #   chain (kcminputrc -> ~/.icons/default -> /usr/share/icons/default) so
    #   it reports the cursor genuinely in effect, not just the kcminputrc key.
    if ! command -v kreadconfig6 &>/dev/null; then
        warn "kreadconfig6 not found — cannot verify effective Plasma settings"
        return 0
    fi
    if [[ -z "${user}" ]]; then
        warn "No UID 1000 user — skipping Plasma visual checks"
        return 0
    fi

    local active_lnf
    active_lnf=$(sudo -H -u "${user}" kreadconfig6 --file kdeglobals --group KDE --key LookAndFeelPackage 2>/dev/null || true)

    local defaults lnf_id line file group key expected actual src found_active=0
    local hdr_re='^\[([^][]+)\]\[([^][]+)\]$'
    while IFS= read -r pkg; do
        [[ -n "${pkg}" ]] || continue
        defaults=$(pacman -Ql "${pkg}" 2>/dev/null | awk '{print $2}' | grep -E '/look-and-feel/[^/]+/contents/defaults$' | head -1 || true)
        [[ -n "${defaults}" && -f "${defaults}" ]] || continue
        lnf_id="${defaults#*/look-and-feel/}"; lnf_id="${lnf_id%%/*}"
        [[ "${lnf_id}" == "${active_lnf}" ]] || continue
        found_active=1
        file=""; group=""
        while IFS= read -r line; do
            if [[ "${line}" =~ $hdr_re ]]; then file="${BASH_REMATCH[1]}"; group="${BASH_REMATCH[2]}"; continue; fi
            [[ "${line}" == \[* ]] && { file=""; group=""; continue; }
            [[ -n "${file}" && "${line}" == *=* ]] || continue
            key="${line%%=*}"; expected="${line#*=}"
            if [[ "${file}" == "kcminputrc" && "${key}" == "cursorTheme" ]]; then
                resolve_cursor "${user}" "${home_dir}"
                actual="${CURSOR_VAL}"; src="${CURSOR_SRC}"
            else
                actual=$(sudo -H -u "${user}" kreadconfig6 --file "${file}" --group "${group}" --key "${key}" 2>/dev/null || true)
                src="${file}"
            fi
            if [[ -z "${actual}" ]]; then
                warn "NOT SET  ${file} [${group}] ${key} — Kiro-Sweet wants '${expected}' (using cascade/system fallback)"
            elif [[ "${actual}" == "${expected}" ]]; then
                pass "SET      ${file} [${group}] ${key} = ${expected}"
            else
                warn "DIFFERS  ${file} [${group}] ${key} = '${actual}' — Kiro-Sweet wants '${expected}' (source: ${src})"
            fi
        done <"${defaults}"
    done <<<"${pkgs}"

    if [[ "${found_active}" -eq 0 ]]; then
        warn "Active look-and-feel for ${user} is '${active_lnf:-<unset>}' — no Kiro Plasma theme applied (cursor/colours/icons won't match)"
    fi
}

#####################################################################
# Main
#####################################################################
main() {
    log_section "Kiro ISO — Installed System Audit"
    echo "  Host   : $(hostname)"
    echo "  Kernel : $(uname -r)"
    echo "  Date   : $(date)"

    local is_vm=false vm_type=""
    if systemd-detect-virt --vm --quiet 2>/dev/null; then
        is_vm=true
        vm_type="$(systemd-detect-virt --vm 2>/dev/null || true)"
        echo "  Virt   : ${vm_type} (virtual machine)"
    fi

    check_kernel
    check_microcode
    check_mkinitcpio
    check_audio
    check_calamares_cleanup
    check_kiro_final_config
    check_pacman_repos
    check_desktop
    check_sddm
    check_kiro_plasma
    check_user_groups
    check_services
    check_systemd_dropins
    check_zram
    check_udev_rules
    check_modprobe_thp
    check_garuda_imports
    check_permissions
    check_sysctl_security
    check_resolved_config
    check_tuned_profile
    check_tumbler
    check_failed_units
    check_dev_rel
    check_nvidia
    check_chwd
    check_bootloader
    check_disk_format
    check_btrfs_snapshots
    check_boot_and_updates
    check_package_integrity

    log_section "Audit Summary"
    echo "  ${GREEN}PASS: ${PASS}${RESET}"
    echo "  ${YELLOW}WARN: ${WARN}${RESET}"
    echo "  ${RED}FAIL: ${FAIL}${RESET}"
    [[ "${FIX_MODE}" == true ]] && echo "  ${CYAN}FIXED: ${FIXED}${RESET}"
    echo

    local rc=0
    if [[ ${FAIL} -gt 0 ]]; then
        if [[ "${FIX_MODE}" == true && ${FIXED} -gt 0 ]]; then
            log_warn "Audit found ${FAIL} failure(s); ${FIXED} fix(es) applied — re-run to confirm"
        else
            log_error "Audit completed with ${FAIL} failure(s)"
        fi
        rc=1
    elif [[ ${WARN} -gt 0 ]]; then
        log_warn "Audit completed with ${WARN} warning(s)"
    else
        log_success "$(basename "$0") — all checks passed"
    fi

    # Keep this last: on a VM the failures above are mostly environment
    # artifacts, so reassure the user rather than let them panic.
    if [[ "${is_vm}" == true ]]; then
        log_warn "You are running on a virtual machine (${vm_type}).
kiro-audit is intended for real (bare-metal) hardware — the
failures above are most likely VM / live-environment artifacts,
not a broken install."
    fi

    exit "${rc}"
}

main "$@"
