#!/bin/bash
set -Euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://kiroproject.be
##################################################################################################################
#
#   DO NOT JUST RUN THIS. EXAMINE AND JUDGE. RUN AT YOUR OWN RISK.
#
#   Purpose:
#   Ranks and updates the pacman mirrorlist using rate-mirrors.
#
#   Why: fresh installs often inherit slow or dead mirrors; ranking by
#   speed dramatically improves pacman performance. See also
#   kiro-get-mirrors (reflector-based alternative).
#
##################################################################################################################

# shellcheck source=/usr/local/lib/roman-os-common.sh
if [[ -f /usr/local/lib/roman-os-common.sh ]]; then
    source /usr/local/lib/roman-os-common.sh
else
    echo "ERROR: roman-os-common.sh not found" >&2
    exit 1
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DRY_RUN=false

main() {
    for arg in "$@"; do
        case "$arg" in
            -h|--help)
                show_help "$(basename "$0")" \
                    "Rank and update the pacman mirrorlist using rate-mirrors" \
                    "[--help] [--version] [--dry-run]" \
                    ""
                exit 0
                ;;
            -v|--version)
                show_version "$(basename "$0")"
                exit 0
                ;;
            -d|--dry-run)
                DRY_RUN=true
                log_info "Dry-run mode enabled — no changes will be made"
                ;;
            *)
                echo "${RED}Unknown option: $arg${RESET}" >&2
                exit 1
                ;;
        esac
    done

    if [ ! -x /usr/bin/rate-mirrors ]; then
        echo "${RED}rate-mirrors is not installed. Please install the 'rate-mirrors' package.${RESET}" >&2
        exit 1
    fi

    log_section "Using rate-mirrors"
    execute_or_dryrun "Rank mirrors and save to /etc/pacman.d/mirrorlist" \
        sudo rate-mirrors --allow-root --disable-comments-in-file --save /etc/pacman.d/mirrorlist arch

    log_success "$(basename "$0") done"
}

main "$@"
