#!/bin/bash
set -Euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://kiroproject.be
##################################################################################################################
#
#   DO NOT JUST RUN THIS. EXAMINE AND JUDGE. RUN AT YOUR OWN RISK.
#
#   Purpose:
#   Replaces /etc/pacman.conf with the Kiro default.
#
#   Why: user edits or a broken upgrade can leave /etc/pacman.conf in a
#   bad state; resetting to the Kiro default restores the expected repo
#   set (including nemesis and chaotic-aur).
#
##################################################################################################################

# shellcheck source=/usr/local/lib/roman-os-common.sh
if [[ -f /usr/local/lib/roman-os-common.sh ]]; then
    source /usr/local/lib/roman-os-common.sh
else
    echo "ERROR: roman-os-common.sh not found" >&2
    exit 1
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DRY_RUN=false

main() {
    for arg in "$@"; do
        case "$arg" in
            -h|--help)
                show_help "$(basename "$0")" \
                    "Replace /etc/pacman.conf with the Kiro default" \
                    "[--help] [--version] [--dry-run]" \
                    ""
                exit 0
                ;;
            -v|--version)
                show_version "$(basename "$0")"
                exit 0
                ;;
            -d|--dry-run)
                DRY_RUN=true
                log_info "Dry-run mode enabled — no changes will be made"
                ;;
            *)
                echo "${RED}Unknown option: $arg${RESET}" >&2
                exit 1
                ;;
        esac
    done

    log_section "Getting /etc/pacman.conf"

    local local_pacman="/usr/local/share/kiro/pacman.conf"

    if [[ ! -f "${local_pacman}" ]]; then
        echo "${RED}Local pacman.conf not found at: ${local_pacman} — cannot proceed${RESET}" >&2
        exit 1
    fi

    log_subsection "Using local pacman.conf"
    if execute_or_dryrun "Copy local pacman.conf to /etc/pacman.conf" sudo cp "${local_pacman}" /etc/pacman.conf; then
        log_success "pacman.conf copied from local system"
        return 0
    else
        log_warn "Failed to copy local pacman.conf"
        exit 1
    fi
}

main "$@"
