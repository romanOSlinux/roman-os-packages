#!/bin/bash
set -Euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://kiroproject.be
##################################################################################################################
#
#   DO NOT JUST RUN THIS. EXAMINE AND JUDGE. RUN AT YOUR OWN RISK.
#
#   Purpose:
#   Fixes pacman keys and GPG configuration — refreshes archlinux-keyring,
#   repopulates keyrings, reloads chaotic-keyring and nemesis-keyring.
#
#   Why: "invalid or corrupted package (PGP signature)" errors are the
#   most common pacman failure mode; this is the canonical recovery.
#
##################################################################################################################

# shellcheck source=/usr/local/lib/kiro-common.sh
if [[ -f /usr/local/lib/kiro-common.sh ]]; then
    source /usr/local/lib/kiro-common.sh
else
    echo "ERROR: kiro-common.sh not found" >&2
    exit 1
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DRY_RUN=false

main() {
    for arg in "$@"; do
        case "$arg" in
            -h|--help)
                show_help "$(basename "$0")" \
                    "Fix pacman keys and GPG configuration" \
                    "[--help] [--version] [--dry-run]" \
                    ""
                exit 0
                ;;
            -v|--version)
                show_version "$(basename "$0")"
                exit 0
                ;;
            -d|--dry-run)
                DRY_RUN=true
                log_info "Dry-run mode enabled — no changes will be made"
                ;;
            *)
                echo "${RED}Unknown option: $arg${RESET}" >&2
                exit 1
                ;;
        esac
    done

    if check_connectivity 3 8.8.8.8; then
        log_subsection "Installing the latest archlinux-keyring package"
        execute_or_dryrun "Install archlinux-keyring" sudo pacman -Sy archlinux-keyring --noconfirm || log_warn "Failed to install archlinux-keyring"
    fi

    log_section "Fixing pacman database and GPG configuration"

    log_subsection "Removing pacman sync databases"
    if [[ -d /var/lib/pacman/sync ]]; then
        execute_or_dryrun "Remove sync databases" sudo rm -f /var/lib/pacman/sync/*.db /var/lib/pacman/sync/*.db.sig || log_warn "Failed to remove all sync databases"
    else
        log_info "Directory not found: /var/lib/pacman/sync"
    fi

    log_subsection "Removing pacman GPG keys"
    if [[ -d /etc/pacman.d/gnupg ]]; then
        execute_or_dryrun "Remove GPG keys" sudo rm -rf /etc/pacman.d/gnupg/* || log_warn "Failed to remove GPG keys"
    else
        log_info "Directory not found: /etc/pacman.d/gnupg"
    fi

    log_subsection "Initializing pacman keys"
    execute_or_dryrun "Initialize pacman keys" sudo pacman-key --init || log_warn "Failed to initialize pacman keys"

    log_subsection "Populating keyring"
    execute_or_dryrun "Populate keyring" sudo pacman-key --populate || log_warn "Failed to populate keyring"

    log_subsection "Adding Ubuntu keyserver to gpg.conf"
    if [[ -f /etc/pacman.d/gnupg/gpg.conf ]]; then
        execute_or_dryrun "Append keyserver to gpg.conf" bash -c 'echo "keyserver hkp://keyserver.ubuntu.com:80" | sudo tee -a /etc/pacman.d/gnupg/gpg.conf >/dev/null'
    else
        log_warn "File not found: /etc/pacman.d/gnupg/gpg.conf"
    fi

    log_subsection "Refreshing pacman databases"
    execute_or_dryrun "Refresh pacman databases" sudo pacman -Sy || log_warn "Failed to refresh pacman databases"

    log_success "$(basename "$0") done"
}

main "$@"
