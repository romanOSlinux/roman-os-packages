#!/bin/bash
set -Euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://kiroproject.be
##################################################################################################################
#
#   DO NOT JUST RUN THIS. EXAMINE AND JUDGE. RUN AT YOUR OWN RISK.
#
#   Purpose:
#   Updates the pacman mirrorlist using reflector.
#
#   Why: alternative to kiro-fix-mirrors (which uses rate-mirrors);
#   reflector is the older / more-standard Arch tool, kept available
#   for users who prefer it.
#
##################################################################################################################

# shellcheck source=/usr/local/lib/kiro-common.sh
if [[ -f /usr/local/lib/kiro-common.sh ]]; then
    source /usr/local/lib/kiro-common.sh
else
    echo "ERROR: kiro-common.sh not found" >&2
    exit 1
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DRY_RUN=false

main() {
    for arg in "$@"; do
        case "$arg" in
            -h|--help)
                show_help "$(basename "$0")" \
                    "Update the pacman mirrorlist using reflector" \
                    "[--help] [--version] [--dry-run]" \
                    ""
                exit 0
                ;;
            -v|--version)
                show_version "$(basename "$0")"
                exit 0
                ;;
            -d|--dry-run)
                DRY_RUN=true
                log_info "Dry-run mode enabled — no changes will be made"
                ;;
            *)
                echo "${RED}Unknown option: $arg${RESET}" >&2
                exit 1
                ;;
        esac
    done

    if test -f /usr/bin/reflector; then
        log_info "reflector is present"
    else
        log_info "Installing reflector"
        execute_or_dryrun "Install reflector" sudo pacman -S reflector --noconfirm
    fi

    execute_or_dryrun "Rank mirrors and save to /etc/pacman.d/mirrorlist" \
        sudo /usr/bin/reflector --score 100 --fastest 10 --number 10 --verbose --save /etc/pacman.d/mirrorlist

    log_success "$(basename "$0") done"
}

main "$@"
