#!/bin/bash
set -Euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://kiroproject.be
##################################################################################################################
#
#   DO NOT JUST RUN THIS. EXAMINE AND JUDGE. RUN AT YOUR OWN RISK.
#
#   Purpose:
#   Prints the Kiro ISO version string from /etc/dev-rel.
#
#   Why: lets users (and ATT) report which ISO produced this install —
#   useful for support tickets and version-conditional behavior.
#
##################################################################################################################

# shellcheck source=/usr/local/lib/roman-os-common.sh
if [[ -f /usr/local/lib/roman-os-common.sh ]]; then
    source /usr/local/lib/roman-os-common.sh
else
    echo "ERROR: roman-os-common.sh not found" >&2
    exit 1
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

main() {
    for arg in "$@"; do
        case "$arg" in
            -h|--help)
                show_help "$(basename "$0")" \
                    "Show the Kiro ISO version string" \
                    "[--help] [--version]" \
                    ""
                exit 0
                ;;
            -v|--version)
                show_version "$(basename "$0")"
                exit 0
                ;;
            *)
                echo "${RED}Unknown option: $arg${RESET}" >&2
                exit 1
                ;;
        esac
    done

    if [[ -f /etc/dev-rel ]]; then
        cat /etc/dev-rel
    else
        log_info "Not on a Kiro ISO."
    fi
    log_success "$(basename "$0") done"
}

main "$@"
