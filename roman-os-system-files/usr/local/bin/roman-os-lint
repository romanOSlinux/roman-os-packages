#!/bin/bash
set -Euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://kiroproject.be
##################################################################################################################
#
#   DO NOT JUST RUN THIS. EXAMINE AND JUDGE. RUN AT YOUR OWN RISK.
#
#   Purpose:
#   Static config analyser for Kiro system configuration files. Checks
#   for duplicate sysctl keys, invalid modprobe parameters, cross-file
#   setting conflicts, and unreachable udev ATTR write targets. Can be
#   pointed at the live / filesystem or at the edu-system-files source
#   tree via --source.
#
#   Why: catches config bugs before they ship — duplicate sysctls,
#   invalid params, conflicting settings — that would otherwise only
#   surface as silent misconfiguration on user systems.
#
##################################################################################################################

# shellcheck source=/usr/local/lib/kiro-common.sh
if [[ -f /usr/local/lib/kiro-common.sh ]]; then
    source /usr/local/lib/kiro-common.sh
else
    echo "ERROR: kiro-common.sh not found" >&2
    exit 1
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

SOURCE="/"
PASS=0
FAIL=0
WARN=0
SKIP=0

ok()         { echo "  ${GREEN}[PASS]${RESET} $1"; PASS=$((PASS+1)); }
ko()         { echo "  ${RED}[FAIL]${RESET} $1"; FAIL=$((FAIL+1)); }
warn_check() { echo "  ${YELLOW}[WARN]${RESET} $1"; WARN=$((WARN+1)); }
skip_check() { echo "  ${CYAN}[SKIP]${RESET} $1"; SKIP=$((SKIP+1)); }

usage() {
    cat <<EOF
Usage: $(basename "$0") [--source <path>]

Static config analyser for kiro system configuration files.
Checks for: duplicate sysctl keys, invalid modprobe parameters,
cross-file setting conflicts, and unreachable udev ATTR write targets.

  --source <path>   Root of the config tree to analyse (default: /)
                    Use the repo path for pre-deployment checks:
                    kiro-lint --source /path/to/edu-system-files
  --help, -h        Show this message and exit
  --version, -v     Show version information and exit
EOF
}

# Join backslash-continuation lines in a file into single logical lines.
_join_lines() {
    sed -e ':a' -e 'N' -e '$!ba' -e 's/\\\n/ /g' "$1"
}

##################################################################################################################
# Check 1 — sysctl duplicate keys
##################################################################################################################
check_sysctl_duplicates() {
    log_subsection "Sysctl: Duplicate Keys"

    local sysctl_dir="$SOURCE/etc/sysctl.d"
    if [[ ! -d "$sysctl_dir" ]]; then
        skip_check "sysctl.d not found: $sysctl_dir"
        return
    fi

    local found_any=0
    for f in "$sysctl_dir"/*.conf; do
        [[ -f "$f" ]] || continue
        found_any=1
        local fname
        fname=$(basename "$f")

        declare -A _seen=()
        local dups=0

        while IFS= read -r line; do
            [[ "$line" =~ ^[[:space:]]*# ]] && continue
            [[ -z "${line//[[:space:]]/}" ]] && continue
            [[ "$line" != *=* ]] && continue

            local key
            key=$(echo "$line" | sed 's/[[:space:]]*=.*//' | tr -d '[:space:]')
            [[ -z "$key" ]] && continue

            if [[ -n "${_seen[$key]+_}" ]]; then
                ko "Duplicate sysctl key '$key' in $fname (last value wins, earlier is dead)"
                dups=$((dups+1))
            else
                _seen[$key]=1
            fi
        done < <(_join_lines "$f")

        if [[ $dups -eq 0 ]]; then ok "No duplicate sysctl keys in $fname"; fi
        unset _seen
    done

    if [[ $found_any -eq 0 ]]; then skip_check "No .conf files found in $sysctl_dir"; fi
}

##################################################################################################################
# Check 2 — modprobe.d parameters vs /sys/module/<driver>/parameters/
##################################################################################################################
check_modprobe_params() {
    log_subsection "Modprobe: Parameters vs /sys/module/"

    local modprobe_dir="$SOURCE/etc/modprobe.d"
    if [[ ! -d "$modprobe_dir" ]]; then
        skip_check "modprobe.d not found: $modprobe_dir"
        return
    fi

    for f in "$modprobe_dir"/*.conf; do
        [[ -f "$f" ]] || continue
        local fname
        fname=$(basename "$f")

        while IFS= read -r line; do
            # Strip leading whitespace before matching
            line="${line#"${line%%[![:space:]]*}"}"
            [[ "$line" =~ ^# ]] && continue
            [[ "$line" =~ ^options[[:space:]] ]] || continue

            local driver
            driver=$(awk '{print $2}' <<< "$line")
            # Kernel module names normalise hyphens to underscores in /sys/module/
            local mod_norm="${driver//-/_}"
            local mod_sysfs="/sys/module/$mod_norm"

            if [[ ! -d "$mod_sysfs" ]]; then
                skip_check "[$fname] module '$driver' not loaded — cannot verify parameters"
                continue
            fi

            local param_dir="$mod_sysfs/parameters"
            if [[ ! -d "$param_dir" ]]; then
                skip_check "[$fname] $driver: /sys/module/$mod_norm/parameters/ absent (no exposed params)"
                continue
            fi

            # Words 3 onward are param=value tokens
            local params_str
            params_str=$(awk '{for(i=3;i<=NF;i++) printf "%s ", $i}' <<< "$line")

            for token in $params_str; do
                [[ "$token" =~ ^# ]] && break
                [[ "$token" != *=* ]] && continue

                local pname
                pname=$(cut -d= -f1 <<< "$token")

                if [[ -e "$param_dir/$pname" ]]; then
                    ok "[$fname] $driver.$pname: exists in sysfs"
                else
                    ko "[$fname] $driver.$pname: not found in $param_dir/"
                fi
            done
        done < <(_join_lines "$f")
    done
}

##################################################################################################################
# Check 3 — conflicting settings across files
#   3a: same driver/param set to different values across modprobe.d files
#   3b: udev ATTR writes that disagree with a modprobe.d option of the same name
##################################################################################################################
check_cross_conflicts() {
    log_subsection "Cross-file: Conflicting Settings"

    local modprobe_dir="$SOURCE/etc/modprobe.d"
    local udev_dir="$SOURCE/etc/udev/rules.d"
    local conflicts=0

    # Build map: "driver:param" -> value and source file
    declare -A _mpvals=()
    declare -A _mpfiles=()

    if [[ -d "$modprobe_dir" ]]; then
        for f in "$modprobe_dir"/*.conf; do
            [[ -f "$f" ]] || continue
            local fname
            fname=$(basename "$f")

            while IFS= read -r line; do
                line="${line#"${line%%[![:space:]]*}"}"
                [[ "$line" =~ ^# ]] && continue
                [[ "$line" =~ ^options[[:space:]] ]] || continue

                local driver
                driver=$(awk '{print $2}' <<< "$line")
                local params_str
                params_str=$(awk '{for(i=3;i<=NF;i++) printf "%s ", $i}' <<< "$line")

                for token in $params_str; do
                    [[ "$token" =~ ^# ]] && break
                    [[ "$token" != *=* ]] && continue

                    local pname pval key
                    pname=$(cut -d= -f1 <<< "$token")
                    pval=$(cut -d= -f2- <<< "$token")
                    key="${driver}:${pname}"

                    if [[ -n "${_mpvals[$key]+_}" ]]; then
                        if [[ "${_mpvals[$key]}" != "$pval" ]]; then
                            ko "modprobe conflict: $driver.$pname='${_mpvals[$key]}' (${_mpfiles[$key]}) vs '$pval' ($fname)"
                            conflicts=$((conflicts+1))
                        else
                            warn_check "modprobe duplicate: $driver.$pname=$pval in ${_mpfiles[$key]} and $fname (redundant)"
                            conflicts=$((conflicts+1))
                        fi
                    else
                        _mpvals[$key]="$pval"
                        _mpfiles[$key]="$fname"
                    fi
                done
            done < <(_join_lines "$f")
        done
    fi

    # Check udev ATTR writes against collected modprobe params by name
    # A match is flagged only when the values differ (udev wins at runtime, so it silently overrides modprobe)
    if [[ -d "$udev_dir" ]] && [[ ${#_mpvals[@]} -gt 0 ]]; then
        for f in "$udev_dir"/*.rules; do
            [[ -f "$f" ]] || continue
            local fname
            fname=$(basename "$f")

            while IFS= read -r line; do
                [[ "$line" =~ ^# ]] && continue
                [[ -z "${line//[[:space:]]/}" ]] && continue

                # Extract ATTR write assignments: ATTR{path}="value"
                # Negative lookbehind (?<!=) excludes match conditions (==)
                local writes
                writes=$(grep -oP 'ATTR\{[^}]+\}(?<!=)="[^"]*"' <<< "$line" 2>/dev/null || true)
                [[ -z "$writes" ]] && continue

                while IFS= read -r w; do
                    [[ -z "$w" ]] && continue

                    local attr_path attr_val attr_leaf
                    attr_path=$(sed 's/ATTR{\([^}]*\)}.*/\1/' <<< "$w")
                    attr_val=$(cut -d'"' -f2 <<< "$w")
                    attr_leaf=$(basename "$attr_path")

                    for key in "${!_mpvals[@]}"; do
                        local mparam="${key#*:}"
                        [[ "$attr_leaf" == "$mparam" ]] || continue

                        local mval="${_mpvals[$key]}"
                        local mfile="${_mpfiles[$key]}"
                        local mdriver="${key%:*}"

                        if [[ "$attr_val" != "$mval" ]]; then
                            warn_check "Possible conflict: modprobe $mdriver.$mparam=$mval ($mfile) vs udev ATTR{$attr_path}=\"$attr_val\" ($fname) — udev wins at runtime"
                            conflicts=$((conflicts+1))
                        fi
                    done
                done <<< "$writes"
            done < <(_join_lines "$f")
        done
    fi

    if [[ $conflicts -eq 0 ]]; then ok "No cross-file config conflicts detected"; fi
}

##################################################################################################################
# Check 4 — udev ATTR write targets exist in sysfs
##################################################################################################################

# Return 0 if attr_path exists under a live sysfs device matching kernel_pat.
# Return 1 if a matching device is present but lacks the attr.
# Return 2 if no device of that type exists (SKIP).
_sysfs_attr_exists() {
    local kernel_pat="$1"
    local attr_path="$2"

    local search_base=""

    # Classify by device family. The KERNEL value is matched as data, not a
    # glob: it literally contains metacharacters (e.g. "sd[a-z]*"), so a case
    # glob like sd[a-z]*) never matches its own pattern string. Use substring
    # tests on the family token instead.
    if [[ "$kernel_pat" == *nvme* || "$kernel_pat" == *sd* || "$kernel_pat" == *mmcblk* || "$kernel_pat" == *vd* ]]; then
        search_base="/sys/block"
    elif [[ "$kernel_pat" == *card* ]]; then
        search_base="/sys/class/sound"
    elif [[ "$kernel_pat" == *eth* || "$kernel_pat" == *en* || "$kernel_pat" == *wl* || "$kernel_pat" == *ww* ]]; then
        search_base="/sys/class/net"
    else
        return 2
    fi

    [[ -d "$search_base" ]] || return 2

    # Handle |-separated kernel patterns (e.g. "sd[a-z]*|nvme*")
    local subpats
    IFS='|' read -ra subpats <<< "$kernel_pat"

    local found_device=0
    for dev in "$search_base"/*/; do
        [[ -d "$dev" ]] || continue
        local dname
        dname=$(basename "$dev")

        local matched_pat=0
        for sp in "${subpats[@]}"; do
            # Extract fixed prefix before any glob characters for a quick prefix check
            local pfx="${sp%%[\[*?]*}"
            [[ "$dname" == "${pfx}"* ]] && matched_pat=1 && break
        done
        [[ $matched_pat -eq 0 ]] && continue

        found_device=1
        [[ -e "${dev%/}/$attr_path" ]] && return 0
    done

    [[ $found_device -eq 0 ]] && return 2
    return 1
}

# Return 0 if attr_path exists on a live device in the given udev subsystem.
# Return 1 if devices of that subsystem exist but none expose the attr.
# Return 2 if no device of that subsystem is present (SKIP).
# Used for rules that match by SUBSYSTEM== rather than KERNEL== (e.g. the
# power/control writes in 61-audio-power and 64-gpu-optimization).
_sysfs_subsystem_attr_exists() {
    local subsystem="$1"
    local attr_path="$2"

    # Bus subsystems (usb, pci, …) expose devices under /sys/bus/<sub>/devices;
    # class subsystems (backlight, sound, …) under /sys/class/<sub>. Try both so
    # power/* attrs on bus devices and class-level attrs are each reachable.
    local bases=("/sys/bus/$subsystem/devices" "/sys/class/$subsystem")

    local found_device=0
    local base dev
    for base in "${bases[@]}"; do
        [[ -d "$base" ]] || continue
        for dev in "$base"/*/; do
            [[ -d "$dev" ]] || continue
            found_device=1
            [[ -e "${dev%/}/$attr_path" ]] && return 0
        done
    done

    [[ $found_device -eq 0 ]] && return 2
    return 1
}

check_udev_attr_targets() {
    log_subsection "Udev: ATTR Write Targets in Sysfs"

    local udev_dir="$SOURCE/etc/udev/rules.d"
    if [[ ! -d "$udev_dir" ]]; then
        skip_check "udev rules.d not found: $udev_dir"
        return
    fi

    for f in "$udev_dir"/*.rules; do
        [[ -f "$f" ]] || continue
        local fname
        fname=$(basename "$f")

        while IFS= read -r line; do
            [[ "$line" =~ ^# ]] && continue
            [[ -z "${line//[[:space:]]/}" ]] && continue

            local writes
            writes=$(grep -oP 'ATTR\{[^}]+\}(?<!=)="[^"]*"' <<< "$line" 2>/dev/null || true)
            [[ -z "$writes" ]] && continue

            # Resolve device type from KERNEL== (preferred) or SUBSYSTEM==
            local kernel_pat subsys
            kernel_pat=$(grep -oP 'KERNEL=="[^"]+"' <<< "$line" 2>/dev/null \
                | head -1 \
                | grep -oP '(?<=")[^"]+' \
                || true)
            subsys=$(grep -oP 'SUBSYSTEM=="[^"]+"' <<< "$line" 2>/dev/null \
                | head -1 \
                | grep -oP '(?<=")[^"]+' \
                || true)

            while IFS= read -r w; do
                [[ -z "$w" ]] && continue

                local attr_path
                attr_path=$(sed 's/ATTR{\([^}]*\)}.*/\1/' <<< "$w")

                local rc=0 ctx
                if [[ -n "$kernel_pat" ]]; then
                    ctx="KERNEL==\"$kernel_pat\""
                    _sysfs_attr_exists "$kernel_pat" "$attr_path" || rc=$?
                elif [[ -n "$subsys" ]]; then
                    ctx="SUBSYSTEM==\"$subsys\""
                    _sysfs_subsystem_attr_exists "$subsys" "$attr_path" || rc=$?
                else
                    skip_check "[$fname] ATTR{$attr_path}: no KERNEL=/SUBSYSTEM= in rule — cannot determine device type"
                    continue
                fi

                case $rc in
                    0) ok "[$fname] ATTR{$attr_path} exists in sysfs ($ctx)" ;;
                    1) ko "[$fname] ATTR{$attr_path}: not found on any $ctx device" ;;
                    2) skip_check "[$fname] ATTR{$attr_path}: no $ctx device to verify against" ;;
                esac
            done <<< "$writes"
        done < <(_join_lines "$f")
    done
}

##################################################################################################################
# Main
##################################################################################################################
main() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --source) SOURCE="${2%/}"; shift 2 ;;
            --help|-h) usage; exit 0 ;;
            --version|-v) show_version "$(basename "$0")"; exit 0 ;;
            *) echo "${RED}Unknown option: $1${RESET}" >&2; exit 1 ;;
        esac
    done

    log_section "Kiro Config Linter"
    log_info "Source: ${SOURCE:-/}"

    check_sysctl_duplicates
    check_modprobe_params
    check_cross_conflicts
    check_udev_attr_targets

    log_section "Lint Summary"
    echo "  ${GREEN}PASS: ${PASS}${RESET}"
    echo "  ${RED}FAIL: ${FAIL}${RESET}"
    echo "  ${YELLOW}WARN: ${WARN}${RESET}"
    echo "  ${CYAN}SKIP: ${SKIP}${RESET}"
    echo

    if [[ $FAIL -gt 0 ]]; then
        log_warn "${FAIL} issue(s) found — fix before deployment"
        exit 1
    elif [[ $WARN -gt 0 ]]; then
        log_warn "${WARN} warning(s) — review recommended"
    else
        log_success "All checks passed"
    fi
}

main "$@"
