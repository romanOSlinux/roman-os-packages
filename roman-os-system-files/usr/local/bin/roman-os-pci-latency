#!/bin/bash
# set -Euo pipefail intentionally omitted: setpci returns non-zero on PCIe root
# ports and other devices that don't implement the latency timer register.
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://kiroproject.be
##################################################################################################################
#
#   DO NOT JUST RUN THIS. EXAMINE AND JUDGE. RUN AT YOUR OWN RISK.
#
#   Purpose:
#   Sets PCI bus latency timers for all devices to a uniform value via
#   setpci.
#
#   Why: old or specific hardware sometimes benefits from a manual PCI
#   latency setting for stability or performance; normalising avoids
#   per-device tuning. (set -Euo pipefail is intentionally omitted —
#   setpci returns non-zero on PCIe root ports and other devices that
#   don't implement the latency timer register.)
#
##################################################################################################################

# shellcheck source=/usr/local/lib/kiro-common.sh
if [[ -f /usr/local/lib/kiro-common.sh ]]; then
    source /usr/local/lib/kiro-common.sh
else
    echo "ERROR: kiro-common.sh not found" >&2
    exit 1
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DRY_RUN=false

for _arg in "$@"; do
    case "$_arg" in
        -h|--help)
            show_help "$(basename "$0")" \
                "Set PCI bus latency timers for all devices" \
                "[--help] [--version] [--dry-run]" \
                ""
            exit 0
            ;;
        -v|--version)
            show_version "$(basename "$0")"
            exit 0
            ;;
        -d|--dry-run)
            DRY_RUN=true
            log_info "Dry-run mode enabled — no changes will be made"
            ;;
    esac
done
unset _arg

ensure_root "$@"

if ! command -v setpci > /dev/null 2>&1; then
    echo "${RED}setpci not found — install pciutils${RESET}" >&2
    exit 1
fi

main() {
    log_section "PCI Latency Timer Optimization"

    if [[ "${DRY_RUN}" == "true" ]]; then
        log_info "[DRY-RUN] Would execute: setpci -s '*:*' latency_timer=20"
        log_info "[DRY-RUN] Would execute: setpci -s '0:0' latency_timer=0"
        log_info "[DRY-RUN] Would execute: setpci -s '*:*:04xx' latency_timer=80"
    else
        # All devices: conservative 20-cycle default
        setpci -s '*:*' latency_timer=20 2>/dev/null || true

        # Northbridge/chipset: 0 = unlimited, for internal bus arbitration
        setpci -s '0:0' latency_timer=0 2>/dev/null || true

        # Multimedia audio (class 04xx): 80 cycles prevents crackling under I/O load
        setpci -s '*:*:04xx' latency_timer=80 2>/dev/null || true
    fi

    log_success "$(basename "$0") done"
}

main "$@"
