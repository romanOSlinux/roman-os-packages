#!/bin/bash
set -Euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://kiroproject.be
##################################################################################################################
#
#   DO NOT JUST RUN THIS. EXAMINE AND JUDGE. RUN AT YOUR OWN RISK.
#
#   Purpose:
#   Uploads a hardware probe to linux-hardware.org (via hw-probe). With
#   --save it instead saves the probe package locally (offline use) and
#   generates a readable HTML insight report from it.
#
#   Why: builds community-visible hardware compatibility data for Kiro
#   installs; --save covers the offline case (server down, no upload) and
#   gives the same data as one readable local file.
#
##################################################################################################################

# shellcheck source=/usr/local/lib/roman-os-common.sh
if [[ -f /usr/local/lib/roman-os-common.sh ]]; then
    source /usr/local/lib/roman-os-common.sh
else
    echo "ERROR: roman-os-common.sh not found" >&2
    exit 1
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DRY_RUN=false
DO_SAVE=false
SAVE_DIR="."

main() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                show_help "$(basename "$0")" \
                    "Upload a hardware probe to linux-hardware.org" \
                    "[--help] [--version] [--dry-run] [--save [DIR]]" \
                    "    -s, --save [DIR]    Save the probe locally (default: current dir) instead of
                        uploading, then generate an HTML insight report from it"
                exit 0
                ;;
            -v|--version)
                show_version "$(basename "$0")"
                exit 0
                ;;
            -d|--dry-run)
                DRY_RUN=true
                log_info "Dry-run mode enabled — no changes will be made"
                ;;
            -s|--save)
                DO_SAVE=true
                if [[ $# -gt 1 && "$2" != -* ]]; then SAVE_DIR="$2"; shift; fi
                ;;
            *)
                echo "${RED}Unknown option: $1${RESET}" >&2
                exit 1
                ;;
        esac
        shift
    done

    if ! pacman -Qi hw-probe &>/dev/null; then
        log_info "hw-probe is not installed. Installing it..."
        execute_or_dryrun "Install hw-probe" sudo pacman -S --noconfirm --needed hw-probe
    fi

    if [[ "${DO_SAVE}" == true ]]; then
        execute_or_dryrun "Save hardware probe to ${SAVE_DIR}" \
            sudo -E /usr/bin/hw-probe -all -save "${SAVE_DIR}"

        # Hand the saved artifacts back to the invoking user when run via sudo.
        if [[ "${DRY_RUN}" == false && -n "${SUDO_USER:-}" ]]; then
            chown -R "${SUDO_USER}:${SUDO_USER}" "${SAVE_DIR}/hw.info" "${SAVE_DIR}/hw.info.txz" 2>/dev/null || true
        fi

        # Generate the readable report from the just-saved package.
        local report_cmd
        report_cmd="$(realpath "${SCRIPT_DIR}/kiro-probe-report" 2>/dev/null || true)"
        [[ -x "${report_cmd}" ]] || report_cmd="kiro-probe-report"
        local report_args=("${SAVE_DIR}/hw.info.txz")
        [[ "${DRY_RUN}" == true ]] && report_args+=(--dry-run)
        execute_or_dryrun "Generate HTML report" "${report_cmd}" "${report_args[@]}"

        [[ "${DRY_RUN}" == false ]] && log_info "We have put the files in your home directory."
    else
        execute_or_dryrun "Run hardware probe and upload" sudo -E /usr/bin/hw-probe -all -upload
    fi

    log_success "$(basename "$0") done"
}

main "$@"
