<?xml version="1.0" encoding="UTF-8"?>
<actions>
<action>
	<icon>utilities-terminal</icon>
	<name>Open Terminal Here</name>
	<submenu></submenu>
	<unique-id>open-terminal</unique-id>
	<command>alacritty</command>
	<description>Open a terminal in this folder</description>
	<range></range>
	<patterns>*</patterns>
	<startup-notify/>
	<directories/>
</action>
<action>
	<icon>utilities-terminal</icon>
	<name>Open Claude Here</name>
	<submenu></submenu>
	<unique-id>open-claude</unique-id>
	<command>alacritty --working-directory %f -e claude</command>
	<description>Open Claude Code in a terminal in this folder</description>
	<range></range>
	<patterns>*</patterns>
	<startup-notify/>
	<directories/>
</action>
<action>
	<icon>com.visualstudio.code</icon>
	<name>Open in VSCode</name>
	<submenu></submenu>
	<unique-id>1748160100000000-1</unique-id>
	<command>code %F</command>
	<description>Open the selection in Visual Studio Code</description>
	<range></range>
	<patterns>*</patterns>
	<directories/>
	<audio-files/>
	<image-files/>
	<other-files/>
	<text-files/>
	<video-files/>
</action>
<action>
	<icon>com.visualstudio.code</icon>
	<name>Open as root in VSCode</name>
	<submenu></submenu>
	<unique-id>1748160100000000-2</unique-id>
	<command>sh -c 'pkexec env DISPLAY=&quot;$DISPLAY&quot; XAUTHORITY=&quot;$XAUTHORITY&quot; code --no-sandbox --user-data-dir=/root/.vscode-root &quot;$@&quot;' _ %F</command>
	<description>Open the selection in Visual Studio Code as root</description>
	<range></range>
	<patterns>*</patterns>
	<directories/>
	<other-files/>
	<text-files/>
</action>
<action>
	<icon>meld</icon>
	<name>Compare</name>
	<submenu></submenu>
	<unique-id>1492232362549799-1</unique-id>
	<command>meld %F</command>
	<description></description>
	<range></range>
	<patterns>*</patterns>
	<directories/>
	<other-files/>
	<text-files/>
</action>
<action>
	<icon>system-file-manager-root</icon>
	<name>Open folder as root</name>
	<submenu></submenu>
	<unique-id>1493475601060449-3</unique-id>
	<command>pkexec thunar %f</command>
	<description></description>
	<range></range>
	<patterns>*</patterns>
	<directories/>
</action>
<action>
	<icon>gittyup</icon>
	<name>Open with gittyup</name>
	<submenu></submenu>
	<unique-id>1587287434852027-1</unique-id>
	<command>gittyup %F</command>
	<description>Open with gittyup</description>
	<range></range>
	<patterns>*</patterns>
	<directories/>
</action>
<action>
	<icon>checkbox</icon>
	<name>Check sha1sum</name>
	<submenu></submenu>
	<unique-id>1526633271260079-26</unique-id>
	<command>zenity --info --title=&quot;Check sha1 for %n&quot; --text=&quot;$(sha1sum %f)&quot;</command>
	<description>Check sha1sum</description>
	<range></range>
	<patterns>*.iso;*.ISO;*.tar.gz;*.TAR.GZ;*.zip;*.ZIP</patterns>
	<other-files/>
</action>
<action>
	<icon>checkbox</icon>
	<name>Check sha256sum</name>
	<submenu></submenu>
	<unique-id>1577688162350307-1</unique-id>
	<command>zenity --info --title=&quot;Check sha256 for %n&quot; --text=&quot;$(sha256sum %f)&quot;</command>
	<description>Check sha256sum</description>
	<range></range>
	<patterns>*.iso;*.ISO;*.tar.gz;*.TAR.GZ;*.zip;*.ZIP</patterns>
	<other-files/>
</action>
<action>
	<icon>checkbox</icon>
	<name>Check md5sum</name>
	<submenu></submenu>
	<unique-id>1526736788575383-2</unique-id>
	<command>zenity --info --title=&quot;Check md5 for %n&quot; --text=&quot;$(md5sum %f)&quot;</command>
	<description>Check md5sum</description>
	<range></range>
	<patterns>*.iso;*.ISO;*.tar.gz;*.TAR.GZ;*.zip;*.ZIP</patterns>
	<other-files/>
</action>
<action>
	<icon>baobab</icon>
	<name>Analyze disk usage</name>
	<submenu></submenu>
	<unique-id>1748160000000000-1</unique-id>
	<command>baobab %f</command>
	<description>Analyze disk usage with Disk Usage Analyzer</description>
	<range></range>
	<patterns>*</patterns>
	<directories/>
</action>
<action>
	<icon>catfish</icon>
	<name>Search with catfish</name>
	<submenu></submenu>
	<unique-id>1489089852658523-2</unique-id>
	<command>catfish --path=$f$d</command>
	<description></description>
	<range></range>
	<patterns>*</patterns>
	<directories/>
</action>
<action>
	<icon>archive-extract</icon>
	<name>Extract here</name>
	<submenu></submenu>
	<unique-id>1489091300385082-4</unique-id>
	<command>sh -c 'case &quot;$1&quot; in *.zip|*.ZIP) unzip &quot;$1&quot; ;; *) tar xf &quot;$1&quot; ;; esac' _ %f</command>
	<description></description>
	<range></range>
	<patterns>*.tar;*.tar.gz;*.tgz;*.tar.bz2;*.tbz2;*.tar.xz;*.txz;*.tar.zst;*.zip;*.ZIP</patterns>
	<other-files/>
</action>
<action>
	<icon>archive-insert</icon>
	<name>Compress here (.tar.gz)</name>
	<submenu></submenu>
	<unique-id>1748160100000000-4</unique-id>
	<command>sh -c 'cd &quot;$(dirname &quot;$1&quot;)&quot; || exit; b=&quot;$(basename &quot;$1&quot;)&quot;; tar czf &quot;$b.tar.gz&quot; &quot;$b&quot;' _ %f</command>
	<description>Compress the selection into a .tar.gz archive</description>
	<range></range>
	<patterns>*</patterns>
	<directories/>
	<other-files/>
	<text-files/>
</action>
<action>
	<icon>applications-graphics</icon>
	<name>Convert png to jpg</name>
	<submenu></submenu>
	<unique-id>1510662686010963-1</unique-id>
	<command>magick %f -background white -flatten -quality 90 &quot;$(basename %f | sed 's/\.[^.]*$/.jpg/')&quot;</command>
	<description>Convert png to jpg</description>
	<range></range>
	<patterns>*.png</patterns>
	<image-files/>
</action>
<action>
	<icon>applications-graphics</icon>
	<name>Convert webp to jpg</name>
	<submenu></submenu>
	<unique-id>1510662686010963-2</unique-id>
	<command>magick %f -background white -flatten -quality 90 &quot;$(basename %f | sed 's/\.[^.]*$/.jpg/')&quot;</command>
	<description>Convert webp to jpg</description>
	<range></range>
	<patterns>*.webp</patterns>
	<image-files/>
</action>
<action>
	<icon>applications-graphics</icon>
	<name>Convert jpg/png to webp</name>
	<submenu></submenu>
	<unique-id>1510662686010963-3</unique-id>
	<command>magick %f -quality 90 &quot;$(basename %f | sed 's/\.[^.]*$/.webp/')&quot;</command>
	<description>Convert jpg/png to webp</description>
	<range></range>
	<patterns>*.jpg;*.jpeg;*.JPG;*.JPEG;*.png;*.PNG</patterns>
	<image-files/>
</action>
<action>
	<icon>application-x-executable</icon>
	<name>Make executable</name>
	<submenu></submenu>
	<unique-id>1526670239648084-2</unique-id>
	<command>chmod +x %f</command>
	<description>Make a file execuble</description>
	<range></range>
	<patterns>*</patterns>
	<other-files/>
	<text-files/>
</action>
<action>
	<icon>com.deepin.ScreenShot</icon>
	<name>Set as wallpaper DS</name>
	<submenu></submenu>
	<unique-id>1637670737487118-1</unique-id>
	<command>feh --bg-fill --no-xinerama %f</command>
	<description>Set as wallpaper using feh dual screen</description>
	<range></range>
	<patterns>*</patterns>
